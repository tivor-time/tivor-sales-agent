      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');\n  \n  :root {\n    --bg-page: hsl(224, 30%, 6%);\n    --bg-surface: hsl(224, 24%, 9%);\n    --text-primary: hsl(213, 22%, 95%);\n    --text-muted: hsl(220, 13%, 64%);\n    --primary: hsl(233, 84%, 70%);\n    --emerald: hsl(158, 64%, 52%);\n    --sky: hsl(198, 90%, 60%);\n    --border: hsl(224, 20%, 15%);\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--bg-page);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-mono { font-family: var(--font-mono); }\n  \n  .glass-card {\n    background: var(--bg-surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .glass-card::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, var(--border), transparent);\n  }\n\n  .sidebar-item:hover .sidebar-label {\n    opacity: 1;\n    transform: translateX(0);\n  }\n\n  .cohort-cell {\n    transition: all 0.2s ease;\n  }\n  .cohort-cell:hover {\n    filter: brightness(1.2);\n    transform: scale(1.02);\n    z-index: 10;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; height: 6px; }\n  ::-webkit-scrollbar-track { background: var(--bg-page); }\n  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"2\"></script>\n\n<div class=\"flex h-[1200px] overflow-hidden\" data-kid=\"3\">\n  \n  <aside class=\"group/sidebar w-16 hover:w-64 transition-all duration-300 border-r border-[hsl(224,20%,15%)] bg-[hsl(224,30%,4%)] flex flex-col z-50\" data-kid=\"4\">\n    <div class=\"p-4 flex items-center gap-3\" data-kid=\"5\">\n      <div class=\"w-8 h-8 bg-indigo-500/20 rounded-lg flex items-center justify-center shrink-0\" data-kid=\"6\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-5 h-5\" style=\"filter: invert(70%) sepia(50%) saturate(1000%) hue-rotate(210deg);\" data-kid=\"7\">\n      </div>\n      <span class=\"font-bold text-lg tracking-tight opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap\" data-kid=\"8\">TradePilot</span>\n    </div>\n    \n    <nav class=\"flex-1 mt-6 px-3 space-y-2\" data-kid=\"9\">\n      <a href=\"#\" class=\"flex items-center gap-4 p-2 rounded-lg text-muted hover:text-white hover:bg-white/5 transition-all\" data-kid=\"10\">\n        <i class=\"ti ti-layout-dashboard text-xl shrink-0\" data-kid=\"11\"></i>\n        <span class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap font-medium\" data-kid=\"12\">Dashboard</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 p-2 rounded-lg text-muted hover:text-white hover:bg-white/5 transition-all\" data-kid=\"13\">\n        <i class=\"ti ti-users text-xl shrink-0\" data-kid=\"14\"></i>\n        <span class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap font-medium\" data-kid=\"15\">Leads</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 p-2 rounded-lg text-muted hover:text-white hover:bg-white/5 transition-all\" data-kid=\"16\">\n        <i class=\"ti ti-send text-xl shrink-0\" data-kid=\"17\"></i>\n        <span class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap font-medium\" data-kid=\"18\">Campaigns</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 p-2 rounded-lg text-muted hover:text-white hover:bg-white/5 transition-all\" data-kid=\"19\">\n        <i class=\"ti ti-inbox text-xl shrink-0\" data-kid=\"20\"></i>\n        <span class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap font-medium\" data-kid=\"21\">Inbox</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 p-2 rounded-lg bg-indigo-500/10 text-indigo-400 border border-indigo-500/20\" data-kid=\"22\">\n        <i class=\"ti ti-bar-chart-2 text-xl shrink-0\" data-kid=\"23\"></i>\n        <span class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap font-medium\" data-kid=\"24\">Analytics</span>\n      </a>\n    </nav>\n\n    <div class=\"p-4 border-t border-border\" data-kid=\"25\">\n      <div class=\"flex items-center gap-3\" data-kid=\"26\">\n        <div class=\"w-8 h-8 rounded-full bg-slate-800 shrink-0\" data-kid=\"27\">\n          <img src=\"https://i.pravatar.cc/32?u=admin\" class=\"w-full h-full rounded-full\" loading=\"lazy\" decoding=\"async\" data-kid=\"28\">\n        </div>\n        <div class=\"opacity-0 group-hover/sidebar:opacity-100 transition-opacity overflow-hidden\" data-kid=\"29\">\n          <p class=\"text-xs font-semibold truncate\" data-kid=\"30\">Alex Rivera</p>\n          <p class=\"text-[10px] text-muted truncate\" data-kid=\"31\">Admin Mode</p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col overflow-auto bg-[url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/burning-dot.svg')] bg-[length:40px_40px] bg-fixed bg-opacity-[0.02]\" data-kid=\"32\">\n    \n    <header class=\"h-16 shrink-0 border-b border-border bg-page/80 backdrop-blur-md flex items-center justify-between px-8 sticky top-0 z-40\" data-kid=\"33\">\n      <div class=\"flex items-center gap-4\" data-kid=\"34\">\n        <h1 class=\"text-xl font-bold tracking-tight\" data-kid=\"35\">Enterprise Analytics</h1>\n        <div class=\"flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20\" data-kid=\"36\">\n          <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"37\"></div>\n          <span class=\"text-[10px] font-bold text-emerald-400 uppercase tracking-widest\" data-kid=\"38\">Live Sync</span>\n        </div>\n      </div>\n      \n      <div class=\"flex-1 max-w-md mx-8\" data-kid=\"39\">\n        <div class=\"relative group\" data-kid=\"40\">\n          <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-muted group-focus-within:text-indigo-400 transition-colors\" data-kid=\"41\"></i>\n          <input type=\"text\" placeholder=\"Jump to campaign, lead, or search data...\" class=\"w-full h-9 pl-10 pr-4 bg-surface border border-border rounded-full text-sm focus:outline-hidden focus:border-indigo-500/50 transition-all placeholder:text-muted/50\" data-kid=\"42\">\n          <div class=\"absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-1\" data-kid=\"43\">\n            <kbd class=\"px-1.5 py-0.5 rounded-sm border border-border bg-page text-[10px] text-muted\" data-kid=\"44\">⌘</kbd>\n            <kbd class=\"px-1.5 py-0.5 rounded-sm border border-border bg-page text-[10px] text-muted\" data-kid=\"45\">K</kbd>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"46\">\n        <button class=\"p-2 text-muted hover:text-white transition-colors relative\" data-kid=\"47\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"48\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-indigo-500 rounded-full border-2 border-page\" data-kid=\"49\"></span>\n        </button>\n        <button class=\"px-4 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold rounded-lg transition-all shadow-lg shadow-indigo-900/20\" data-kid=\"50\">Export PDF</button>\n      </div>\n    </header>\n\n    <div class=\"p-8 space-y-8\" data-kid=\"51\">\n      \n      <div class=\"grid grid-cols-12 gap-8\" data-kid=\"52\">\n        \n        <section class=\"col-span-8 glass-card p-6\" data-kid=\"53\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"54\">\n            <div data-kid=\"55\">\n              <h2 class=\"text-sm font-bold uppercase tracking-wider text-muted flex items-center gap-2\" data-kid=\"56\">\n                <i class=\"ti ti-world text-indigo-400\" data-kid=\"57\"></i>\n                Geographic Performance Heatmap\n              </h2>\n              <p class=\"text-xs text-muted/60 mt-1\" data-kid=\"58\">Lead engagement density by global region.</p>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"59\">\n              <div class=\"flex items-center gap-2\" data-kid=\"60\">\n                <span class=\"w-2 h-2 rounded-full bg-indigo-500\" data-kid=\"61\"></span>\n                <span class=\"text-[10px] font-mono uppercase tracking-tighter text-muted\" data-kid=\"62\">Targeted</span>\n              </div>\n              <div class=\"flex items-center gap-2\" data-kid=\"63\">\n                <span class=\"w-2 h-2 rounded-full bg-emerald-500\" data-kid=\"64\"></span>\n                <span class=\"text-[10px] font-mono uppercase tracking-tighter text-muted\" data-kid=\"65\">High Growth</span>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"relative h-[320px] flex items-center justify-center\" data-kid=\"66\">\n            \n            <svg viewBox=\"0 0 1000 500\" class=\"w-full h-full opacity-40\" data-kid=\"67\">\n              <path fill=\"currentColor\" class=\"text-slate-800\" d=\"M250,150 L300,150 L320,180 L280,220 L240,200 Z\" data-kid=\"68\"></path> \n              <path fill=\"var(--primary)\" class=\"animate-pulse\" style=\"animation-duration: 4s;\" d=\"M280,160 L310,170 L290,200 L260,190 Z\" data-kid=\"69\"></path> \n              <path fill=\"currentColor\" class=\"text-slate-800\" d=\"M600,100 L650,90 L700,120 L680,180 L620,160 Z\" data-kid=\"70\"></path> \n              <path fill=\"var(--emerald)\" class=\"animate-pulse\" style=\"animation-duration: 3s;\" d=\"M630,120 L660,110 L650,140 L620,150 Z\" data-kid=\"71\"></path> \n              <path fill=\"currentColor\" class=\"text-slate-800\" d=\"M350,300 L400,280 L420,350 L370,400 L330,350 Z\" data-kid=\"72\"></path> \n              <path fill=\"currentColor\" class=\"text-slate-800\" d=\"M500,250 L550,230 L580,280 L540,350 L490,320 Z\" data-kid=\"73\"></path> \n              <path fill=\"var(--sky)\" class=\"animate-pulse\" style=\"animation-duration: 5s;\" d=\"M520,270 L550,260 L540,290 L510,300 Z\" data-kid=\"74\"></path> \n              <circle cx=\"280\" cy=\"180\" r=\"4\" fill=\"white\" class=\"animate-ping\" data-kid=\"75\"></circle>\n              <circle cx=\"640\" cy=\"130\" r=\"4\" fill=\"white\" class=\"animate-ping\" data-kid=\"76\"></circle>\n            </svg>\n            \n            <div class=\"absolute bottom-0 right-0 p-4 flex flex-col items-end gap-2\" data-kid=\"77\">\n              <div class=\"text-right\" data-kid=\"78\">\n                <p class=\"text-xs text-muted font-medium\" data-kid=\"79\">Top Territory</p>\n                <p class=\"text-2xl font-bold font-mono text-indigo-400\" data-kid=\"80\">NORTH AMERICA</p>\n              </div>\n              <div class=\"text-right\" data-kid=\"81\">\n                <p class=\"text-xs text-muted font-medium\" data-kid=\"82\">Conversion Delta</p>\n                <p class=\"text-lg font-bold font-mono text-emerald-400\" data-kid=\"83\">+14.2%</p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"col-span-4 glass-card p-6 flex flex-col\" data-kid=\"84\">\n          <h2 class=\"text-sm font-bold uppercase tracking-wider text-muted mb-6 flex items-center gap-2\" data-kid=\"85\">\n            <i class=\"ti ti-chart-pie text-sky-400\" data-kid=\"86\"></i>\n            Channel Attribution\n          </h2>\n          \n          <div class=\"flex-1 flex flex-col justify-center items-center relative\" data-kid=\"87\">\n            <div class=\"w-48 h-48\" data-kid=\"88\">\n              <canvas id=\"attributionChart\" data-kid=\"89\"></canvas>\n            </div>\n            <div class=\"absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-4\" data-kid=\"90\">\n              <p class=\"text-[10px] text-muted font-bold uppercase tracking-widest\" data-kid=\"91\">Total Ops</p>\n              <p class=\"text-2xl font-bold font-mono tracking-tighter\" data-kid=\"92\">4.2k</p>\n            </div>\n          </div>\n\n          <div class=\"mt-8 grid grid-cols-2 gap-4\" data-kid=\"93\">\n            <div class=\"p-3 rounded-xl bg-indigo-500/5 border border-indigo-500/10\" data-kid=\"94\">\n              <p class=\"text-[10px] font-bold text-indigo-400 uppercase\" data-kid=\"95\">Email</p>\n              <p class=\"text-xl font-bold font-mono mt-1 tracking-tighter\" data-kid=\"96\">68%</p>\n              <p class=\"text-[10px] text-muted mt-1 leading-tight\" data-kid=\"97\">High volume, steady intent.</p>\n            </div>\n            <div class=\"p-3 rounded-xl bg-sky-500/5 border border-sky-500/10\" data-kid=\"98\">\n              <p class=\"text-[10px] font-bold text-sky-400 uppercase\" data-kid=\"99\">LinkedIn</p>\n              <p class=\"text-xl font-bold font-mono mt-1 tracking-tighter\" data-kid=\"100\">32%</p>\n              <p class=\"text-[10px] text-muted mt-1 leading-tight\" data-kid=\"101\">High intent, low volume.</p>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      \n      <section class=\"glass-card\" data-kid=\"102\">\n        <div class=\"p-6 border-b border-border flex items-center justify-between\" data-kid=\"103\">\n          <div data-kid=\"104\">\n            <h2 class=\"text-sm font-bold uppercase tracking-wider text-muted flex items-center gap-2\" data-kid=\"105\">\n              <i class=\"ti ti-table text-emerald-400\" data-kid=\"106\"></i>\n              Lead Retention Cohort Analysis\n            </h2>\n            <p class=\"text-xs text-muted/60 mt-1\" data-kid=\"107\">Percentage of leads retained/converted over time by signup month.</p>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"108\">\n            <button class=\"px-3 py-1 bg-surface border border-border rounded text-[10px] font-bold text-muted hover:text-white transition-colors\" data-kid=\"109\">By Volume</button>\n            <button class=\"px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded text-[10px] font-bold text-indigo-400\" data-kid=\"110\">By Percent %</button>\n          </div>\n        </div>\n        \n        <div class=\"overflow-x-auto p-4\" data-kid=\"111\">\n          <table class=\"w-full text-left border-separate border-spacing-1\" data-kid=\"112\">\n            <thead data-kid=\"113\">\n              <tr class=\"text-[10px] font-bold text-muted uppercase tracking-widest\" data-kid=\"114\">\n                <th class=\"p-3 w-32\" data-kid=\"115\">Cohort Month</th>\n                <th class=\"p-3 w-24\" data-kid=\"116\">Size</th>\n                <th class=\"p-3 bg-indigo-500/5 rounded-t-lg\" data-kid=\"117\">Month 0</th>\n                <th class=\"p-3\" data-kid=\"118\">Month 1</th>\n                <th class=\"p-3\" data-kid=\"119\">Month 2</th>\n                <th class=\"p-3\" data-kid=\"120\">Month 3</th>\n                <th class=\"p-3\" data-kid=\"121\">Month 4</th>\n                <th class=\"p-3\" data-kid=\"122\">Month 5</th>\n                <th class=\"p-3\" data-kid=\"123\">Month 6</th>\n              </tr>\n            </thead>\n            <tbody class=\"text-xs font-mono font-medium\" data-kid=\"124\">\n              \n              <tr data-kid=\"125\">\n                <td class=\"p-3 text-white font-bold font-sans\" data-kid=\"126\">Jan 2026</td>\n                <td class=\"p-3 text-muted\" data-kid=\"127\">1,240</td>\n                <td class=\"p-3 bg-indigo-500 rounded-lg text-white flex items-center justify-center font-bold\" data-kid=\"128\">100%</td>\n                <td class=\"p-3 bg-indigo-500/80 rounded-lg text-white flex items-center justify-center\" data-kid=\"129\">84.2%</td>\n                <td class=\"p-3 bg-indigo-500/60 rounded-lg text-white/80 flex items-center justify-center\" data-kid=\"130\">72.1%</td>\n                <td class=\"p-3 bg-indigo-500/40 rounded-lg text-white/70 flex items-center justify-center\" data-kid=\"131\">64.5%</td>\n                <td class=\"p-3 bg-indigo-500/30 rounded-lg text-white/60 flex items-center justify-center\" data-kid=\"132\">52.8%</td>\n                <td class=\"p-3 bg-indigo-500/20 rounded-lg text-white/50 flex items-center justify-center\" data-kid=\"133\">44.1%</td>\n                <td class=\"p-3 bg-indigo-500/10 rounded-lg text-white/40 flex items-center justify-center\" data-kid=\"134\">38.9%</td>\n              </tr>\n              \n              <tr data-kid=\"135\">\n                <td class=\"p-3 text-white font-bold font-sans\" data-kid=\"136\">Feb 2026</td>\n                <td class=\"p-3 text-muted\" data-kid=\"137\">980</td>\n                <td class=\"p-3 bg-indigo-500 rounded-lg text-white flex items-center justify-center font-bold\" data-kid=\"138\">100%</td>\n                <td class=\"p-3 bg-indigo-500/80 rounded-lg text-white flex items-center justify-center\" data-kid=\"139\">88.5%</td>\n                <td class=\"p-3 bg-indigo-500/70 rounded-lg text-white/80 flex items-center justify-center\" data-kid=\"140\">79.2%</td>\n                <td class=\"p-3 bg-indigo-500/50 rounded-lg text-white/70 flex items-center justify-center\" data-kid=\"141\">68.4%</td>\n                <td class=\"p-3 bg-indigo-500/40 rounded-lg text-white/60 flex items-center justify-center\" data-kid=\"142\">58.2%</td>\n                <td class=\"p-3 bg-indigo-500/30 rounded-lg text-white/50 flex items-center justify-center\" data-kid=\"143\">49.7%</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"144\">-</td>\n              </tr>\n              \n              <tr data-kid=\"145\">\n                <td class=\"p-3 text-white font-bold font-sans\" data-kid=\"146\">Mar 2026</td>\n                <td class=\"p-3 text-muted\" data-kid=\"147\">2,150</td>\n                <td class=\"p-3 bg-indigo-500 rounded-lg text-white flex items-center justify-center font-bold\" data-kid=\"148\">100%</td>\n                <td class=\"p-3 bg-indigo-500/90 rounded-lg text-white flex items-center justify-center\" data-kid=\"149\">92.1%</td>\n                <td class=\"p-3 bg-indigo-500/70 rounded-lg text-white/80 flex items-center justify-center\" data-kid=\"150\">81.5%</td>\n                <td class=\"p-3 bg-indigo-500/60 rounded-lg text-white/70 flex items-center justify-center\" data-kid=\"151\">72.3%</td>\n                <td class=\"p-3 bg-indigo-500/50 rounded-lg text-white/60 flex items-center justify-center\" data-kid=\"152\">64.9%</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"153\">-</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"154\">-</td>\n              </tr>\n              \n              <tr data-kid=\"155\">\n                <td class=\"p-3 text-white font-bold font-sans\" data-kid=\"156\">Apr 2026</td>\n                <td class=\"p-3 text-muted\" data-kid=\"157\">1,670</td>\n                <td class=\"p-3 bg-indigo-500 rounded-lg text-white flex items-center justify-center font-bold\" data-kid=\"158\">100%</td>\n                <td class=\"p-3 bg-indigo-500/80 rounded-lg text-white flex items-center justify-center\" data-kid=\"159\">85.4%</td>\n                <td class=\"p-3 bg-indigo-500/60 rounded-lg text-white/80 flex items-center justify-center\" data-kid=\"160\">74.2%</td>\n                <td class=\"p-3 bg-indigo-500/50 rounded-lg text-white/70 flex items-center justify-center\" data-kid=\"161\">66.1%</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"162\">-</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"163\">-</td>\n                <td class=\"p-3 border border-dashed border-border rounded-lg text-muted flex items-center justify-center\" data-kid=\"164\">-</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </section>\n\n      \n      <section class=\"glass-card p-6\" data-kid=\"165\">\n        <div class=\"flex items-center justify-between mb-8\" data-kid=\"166\">\n          <div data-kid=\"167\">\n            <h2 class=\"text-sm font-bold uppercase tracking-wider text-muted flex items-center gap-2\" data-kid=\"168\">\n              <i class=\"ti ti-chart-line text-pink-400\" data-kid=\"169\"></i>\n              Lead Sentiment Trends\n            </h2>\n            <p class=\"text-xs text-muted/60 mt-1\" data-kid=\"170\">AI-analyzed emotional tone from outreach replies over time.</p>\n          </div>\n          <div class=\"flex items-center gap-6\" data-kid=\"171\">\n            <div class=\"flex items-center gap-2\" data-kid=\"172\">\n              <span class=\"w-3 h-1 rounded-full bg-emerald-500\" data-kid=\"173\"></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-tight text-muted\" data-kid=\"174\">Positive Intent</span>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"175\">\n              <span class=\"w-3 h-1 rounded-full bg-slate-500\" data-kid=\"176\"></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-tight text-muted\" data-kid=\"177\">Neutral</span>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"178\">\n              <span class=\"w-3 h-1 rounded-full bg-red-500\" data-kid=\"179\"></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-tight text-muted\" data-kid=\"180\">Negative</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"h-[300px] w-full\" data-kid=\"181\">\n          <canvas id=\"sentimentChart\" data-kid=\"182\"></canvas>\n        </div>\n      </section>\n    </div>\n  </main>\n</div>\n\n<script data-kid=\"183\">\n  window.addEventListener('load', () => {\n    // Channel Attribution Chart\n    const attributionCtx = document.getElementById('attributionChart').getContext('2d');\n    new Chart(attributionCtx, {\n      type: 'doughnut',\n      data: {\n        labels: ['Email', 'LinkedIn'],\n        datasets: [{\n          data: [68, 32],\n          backgroundColor: [\n            'hsl(233, 84%, 70%)', // Indigo\n            'hsl(198, 90%, 60%)'  // Sky\n          ],\n          borderWidth: 0,\n          hoverOffset: 4,\n          borderRadius: 4\n        }]\n      },\n      options: {\n        cutout: '80%',\n        plugins: {\n          legend: { display: false }\n        }\n      }\n    });\n\n    // Sentiment Trends Chart\n    const sentimentCtx = document.getElementById('sentimentChart').getContext('2d');\n    new Chart(sentimentCtx, {\n      type: 'line',\n      data: {\n        labels: ['Jan 01', 'Jan 05', 'Jan 10', 'Jan 15', 'Jan 20', 'Jan 25', 'Jan 30'],\n        datasets: [\n          {\n            label: 'Positive',\n            data: [20, 25, 45, 40, 55, 65, 70],\n            borderColor: 'hsl(158, 64%, 52%)',\n            borderWidth: 3,\n            tension: 0.4,\n            pointRadius: 0,\n            fill: true,\n            backgroundColor: 'hsla(158, 64%, 52%, 0.1)'\n          },\n          {\n            label: 'Neutral',\n            data: [50, 45, 35, 45, 30, 25, 20],\n            borderColor: 'hsl(220, 13%, 44%)',\n            borderWidth: 2,\n            tension: 0.4,\n            pointRadius: 0,\n            borderDash: [5, 5]\n          },\n          {\n            label: 'Negative',\n            data: [10, 15, 8, 12, 5, 8, 4],\n            borderColor: '#ef4444',\n            borderWidth: 2,\n            tension: 0.4,\n            pointRadius: 0\n          }\n        ]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: {\n          legend: { display: false }\n        },\n        scales: {\n          y: {\n            grid: { color: 'rgba(255, 255, 255, 0.05)' },\n            ticks: {\n              color: 'rgba(255, 255, 255, 0.4)',\n              font: { family: 'JetBrains Mono', size: 10 },\n              callback: value => value + '%'\n            }\n          },\n          x: {\n            grid: { display: false },\n            ticks: {\n              color: 'rgba(255, 255, 255, 0.4)',\n              font: { family: 'JetBrains Mono', size: 10 }\n            }\n          }\n        }\n      }\n    });\n  });\n</script>",
