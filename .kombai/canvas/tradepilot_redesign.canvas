      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #0a0d14; /* hsl(224, 30%, 6%) */\n    color: #e2e8f0;\n    margin: 0;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .grid-bg {\n    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.05) 1px, transparent 1px);\n    background-size: 24px 24px;\n  }\n\n  .glass-card {\n    background-color: #0e121b; /* hsl(224, 24%, 9%) */\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n  }\n\n  .sidebar-gradient {\n    border-right: 1px solid transparent;\n    border-image: linear-gradient(to bottom, transparent, rgba(123, 138, 242, 0.3), transparent) 1;\n  }\n\n  /* Custom scrollbar */\n  .scrollbar-thin::-webkit-scrollbar {\n    width: 4px;\n  }\n  .scrollbar-thin::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .scrollbar-thin::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 2px;\n  }\n</style>\n\n<div class=\"flex h-[900px] grid-bg overflow-hidden\" data-kid=\"1\">\n  \n  <aside class=\"w-16 sidebar-gradient flex flex-col items-center py-6 gap-8 bg-[#0a0d14]/80 backdrop-blur-md z-20\" data-kid=\"2\">\n    <div class=\"p-2 bg-indigo-500/10 rounded-lg\" data-kid=\"3\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-8 h-8 filter invert-[.8] sepia-[.5] saturate-[5] hue-rotate-[200deg]\" alt=\"Logo\" data-kid=\"4\">\n    </div>\n    \n    <nav class=\"flex flex-col gap-4\" data-kid=\"5\">\n      <button class=\"p-3 rounded-xl bg-indigo-500/10 text-indigo-400\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"p-3 rounded-xl text-slate-500 hover:text-slate-300 transition-colors\" data-kid=\"8\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"p-3 rounded-xl text-slate-500 hover:text-slate-300 transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-send text-2xl\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"p-3 rounded-xl text-slate-500 hover:text-slate-300 transition-colors\" data-kid=\"12\">\n        <i class=\"ti ti-inbox text-2xl\" data-kid=\"13\"></i>\n      </button>\n      <button class=\"p-3 rounded-xl text-slate-500 hover:text-slate-300 transition-colors\" data-kid=\"14\">\n        <i class=\"ti ti-bar-chart-2 text-2xl\" data-kid=\"15\"></i>\n      </button>\n    </nav>\n    \n    <div class=\"mt-auto flex flex-col gap-4\" data-kid=\"16\">\n      <button class=\"p-3 rounded-xl text-slate-500 hover:text-slate-300 transition-colors\" data-kid=\"17\">\n        <i class=\"ti ti-settings text-2xl\" data-kid=\"18\"></i>\n      </button>\n      <div class=\"w-8 h-8 rounded-full bg-slate-800 border border-slate-700 overflow-hidden\" data-kid=\"19\">\n        <img src=\"https://i.pravatar.cc/100?u=tradepilot\" alt=\"User\" class=\"w-full h-full object-cover\" data-kid=\"20\">\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col overflow-hidden\" data-kid=\"21\">\n    \n    <header class=\"h-16 flex items-center justify-between px-8 border-b border-white/5 bg-[#0a0d14]/50 backdrop-blur-md z-10\" data-kid=\"22\">\n      <div class=\"flex items-center gap-4\" data-kid=\"23\">\n        <h1 class=\"text-sm font-medium text-slate-400 uppercase tracking-widest\" data-kid=\"24\">Mission Control</h1>\n        <div class=\"h-4 w-px bg-white/10\" data-kid=\"25\"></div>\n        <div class=\"flex items-center gap-2\" data-kid=\"26\">\n          <span class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"27\"></span>\n          <span class=\"text-xs font-mono text-emerald-500/80\" data-kid=\"28\">LIVE FEED</span>\n        </div>\n      </div>\n\n      <div class=\"relative w-96 group\" data-kid=\"29\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 group-focus-within:text-indigo-400 transition-colors\" data-kid=\"30\"></i>\n        <input type=\"text\" placeholder=\"Search campaigns, leads, or type '/' for commands...\" class=\"w-full bg-white/5 border border-white/10 rounded-full py-2 pl-12 pr-4 text-sm focus:outline-hidden focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition-all placeholder:text-slate-600\" data-kid=\"31\">\n      </div>\n\n      <div class=\"flex items-center gap-6\" data-kid=\"32\">\n        <div class=\"flex items-center gap-4\" data-kid=\"33\">\n          <div class=\"flex flex-col items-end\" data-kid=\"34\">\n            <span class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"35\">Deliverability</span>\n            <span class=\"text-xs font-mono text-emerald-400\" data-kid=\"36\">98.4%</span>\n          </div>\n          <div class=\"w-24 h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"37\">\n            <div class=\"h-full bg-emerald-500 w-[98%]\" data-kid=\"38\"></div>\n          </div>\n        </div>\n        <button class=\"relative p-2 text-slate-400 hover:text-white transition-colors\" data-kid=\"39\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"40\"></i>\n          <span class=\"absolute top-1.5 right-1.5 w-2 h-2 bg-indigo-500 rounded-full border-2 border-[#0a0d14]\" data-kid=\"41\"></span>\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 overflow-y-auto p-8 scrollbar-thin\" data-kid=\"42\">\n      <div class=\"max-w-(--breakpoint-2xl) mx-auto space-y-6\" data-kid=\"43\">\n        \n        \n        <div class=\"grid grid-cols-4 gap-6\" data-kid=\"44\">\n          \n          <div class=\"glass-card p-6 rounded-2xl relative overflow-hidden group\" data-kid=\"45\">\n            <div class=\"absolute top-0 right-0 w-24 h-24 bg-indigo-500/5 blur-3xl -mr-8 -mt-8\" data-kid=\"46\"></div>\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"47\">\n              <span class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"48\">Pipeline Value</span>\n              <span class=\"text-xs text-emerald-400 bg-emerald-400/10 px-1.5 py-0.5 rounded-md font-mono\" data-kid=\"49\">+12.4%</span>\n            </div>\n            <div class=\"text-3xl font-bold font-mono text-white mb-4\" data-kid=\"50\">$1.42M</div>\n            <div class=\"h-10 w-full\" id=\"sparkline-1\" data-kid=\"51\"></div>\n          </div>\n          \n          \n          <div class=\"glass-card p-6 rounded-2xl relative overflow-hidden\" data-kid=\"52\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"53\">\n              <span class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"54\">Active Leads</span>\n              <span class=\"text-xs text-indigo-400 bg-indigo-400/10 px-1.5 py-0.5 rounded-md font-mono\" data-kid=\"55\">2.4k</span>\n            </div>\n            <div class=\"text-3xl font-bold font-mono text-white mb-4\" data-kid=\"56\">12,842</div>\n            <div class=\"h-10 w-full\" id=\"sparkline-2\" data-kid=\"57\"></div>\n          </div>\n\n          \n          <div class=\"glass-card p-6 rounded-2xl relative overflow-hidden\" data-kid=\"58\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"59\">\n              <span class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"60\">Response Rate</span>\n              <span class=\"text-xs text-sky-400 bg-sky-400/10 px-1.5 py-0.5 rounded-md font-mono\" data-kid=\"61\">Avg 18%</span>\n            </div>\n            <div class=\"text-3xl font-bold font-mono text-white mb-4\" data-kid=\"62\">24.2%</div>\n            <div class=\"h-10 w-full\" id=\"sparkline-3\" data-kid=\"63\"></div>\n          </div>\n\n          \n          <div class=\"glass-card p-6 rounded-2xl relative overflow-hidden\" data-kid=\"64\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"65\">\n              <span class=\"text-xs font-medium text-slate-500 uppercase tracking-wider\" data-kid=\"66\">Bounce Rate</span>\n              <span class=\"text-xs text-rose-400 bg-rose-400/10 px-1.5 py-0.5 rounded-md font-mono\" data-kid=\"67\">-0.4%</span>\n            </div>\n            <div class=\"text-3xl font-bold font-mono text-white mb-4\" data-kid=\"68\">0.82%</div>\n            <div class=\"h-10 w-full\" id=\"sparkline-4\" data-kid=\"69\"></div>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-3 gap-6\" data-kid=\"70\">\n          \n          <div class=\"col-span-2 glass-card rounded-2xl overflow-hidden flex flex-col\" data-kid=\"71\">\n            <div class=\"p-6 border-b border-white/5 flex items-center justify-between\" data-kid=\"72\">\n              <h2 class=\"text-sm font-semibold text-slate-200 uppercase tracking-wider flex items-center gap-2\" data-kid=\"73\">\n                <i class=\"ti ti-send text-indigo-400\" data-kid=\"74\"></i>\n                Campaign Activity\n              </h2>\n              <button class=\"text-xs text-indigo-400 hover:text-indigo-300 font-medium\" data-kid=\"75\">View All</button>\n            </div>\n            <div class=\"p-6 space-y-6\" data-kid=\"76\">\n              \n              <div class=\"space-y-3\" data-kid=\"77\">\n                <div class=\"flex items-center justify-between\" data-kid=\"78\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"79\">\n                    <div class=\"w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400\" data-kid=\"80\">\n                      <i class=\"ti ti-mail\" data-kid=\"81\"></i>\n                    </div>\n                    <div data-kid=\"82\">\n                      <div class=\"text-sm font-semibold text-slate-200\" data-kid=\"83\">Q3 Enterprise Expansion</div>\n                      <div class=\"text-xs text-slate-500\" data-kid=\"84\">Target: Fortune 500 • 1,200 leads</div>\n                    </div>\n                  </div>\n                  <div class=\"flex gap-4\" data-kid=\"85\">\n                    <div class=\"text-right\" data-kid=\"86\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"87\">Sent</div>\n                      <div class=\"text-xs font-mono\" data-kid=\"88\">842</div>\n                    </div>\n                    <div class=\"text-right\" data-kid=\"89\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"90\">Replies</div>\n                      <div class=\"text-xs font-mono text-emerald-400\" data-kid=\"91\">124</div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"grid grid-cols-3 gap-2\" data-kid=\"92\">\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"93\">\n                    <div class=\"h-full bg-indigo-500 w-[70%]\" data-kid=\"94\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"95\">\n                    <div class=\"h-full bg-emerald-500 w-[15%]\" data-kid=\"96\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"97\">\n                    <div class=\"h-full bg-rose-500 w-[2%]\" data-kid=\"98\"></div>\n                  </div>\n                </div>\n              </div>\n\n              \n              <div class=\"space-y-3\" data-kid=\"99\">\n                <div class=\"flex items-center justify-between\" data-kid=\"100\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"101\">\n                    <div class=\"w-10 h-10 rounded-lg bg-sky-500/10 flex items-center justify-center text-sky-400\" data-kid=\"102\">\n                      <i class=\"ti ti-link\" data-kid=\"103\"></i>\n                    </div>\n                    <div data-kid=\"104\">\n                      <div class=\"text-sm font-semibold text-slate-200\" data-kid=\"105\">LinkedIn Outreach - SaaS Founders</div>\n                      <div class=\"text-xs text-slate-500\" data-kid=\"106\">Target: Series B Founders • 450 leads</div>\n                    </div>\n                  </div>\n                  <div class=\"flex gap-4\" data-kid=\"107\">\n                    <div class=\"text-right\" data-kid=\"108\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"109\">Sent</div>\n                      <div class=\"text-xs font-mono\" data-kid=\"110\">312</div>\n                    </div>\n                    <div class=\"text-right\" data-kid=\"111\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"112\">Replies</div>\n                      <div class=\"text-xs font-mono text-emerald-400\" data-kid=\"113\">82</div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"grid grid-cols-3 gap-2\" data-kid=\"114\">\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"115\">\n                    <div class=\"h-full bg-sky-500 w-[69%]\" data-kid=\"116\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"117\">\n                    <div class=\"h-full bg-emerald-500 w-[26%]\" data-kid=\"118\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"119\">\n                    <div class=\"h-full bg-rose-500 w-[1%]\" data-kid=\"120\"></div>\n                  </div>\n                </div>\n              </div>\n\n              \n              <div class=\"space-y-3\" data-kid=\"121\">\n                <div class=\"flex items-center justify-between\" data-kid=\"122\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"123\">\n                    <div class=\"w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400\" data-kid=\"124\">\n                      <i class=\"ti ti-microphone\" data-kid=\"125\"></i>\n                    </div>\n                    <div data-kid=\"126\">\n                      <div class=\"text-sm font-semibold text-slate-200\" data-kid=\"127\">Conference Follow-up</div>\n                      <div class=\"text-xs text-slate-500\" data-kid=\"128\">Target: WebSummit Attendees • 85 leads</div>\n                    </div>\n                  </div>\n                  <div class=\"flex gap-4\" data-kid=\"129\">\n                    <div class=\"text-right\" data-kid=\"130\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"131\">Sent</div>\n                      <div class=\"text-xs font-mono\" data-kid=\"132\">85</div>\n                    </div>\n                    <div class=\"text-right\" data-kid=\"133\">\n                      <div class=\"text-[10px] text-slate-500 uppercase\" data-kid=\"134\">Replies</div>\n                      <div class=\"text-xs font-mono text-emerald-400\" data-kid=\"135\">42</div>\n                    </div>\n                  </div>\n                </div>\n                <div class=\"grid grid-cols-3 gap-2\" data-kid=\"136\">\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"137\">\n                    <div class=\"h-full bg-emerald-500 w-[100%]\" data-kid=\"138\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"139\">\n                    <div class=\"h-full bg-emerald-500 w-[49%]\" data-kid=\"140\"></div>\n                  </div>\n                  <div class=\"h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"141\">\n                    <div class=\"h-full bg-rose-500 w-[0%]\" data-kid=\"142\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"glass-card rounded-2xl flex flex-col\" data-kid=\"143\">\n            <div class=\"p-6 border-b border-white/5\" data-kid=\"144\">\n              <h2 class=\"text-sm font-semibold text-slate-200 uppercase tracking-wider flex items-center gap-2\" data-kid=\"145\">\n                <i class=\"ti ti-clock text-amber-400\" data-kid=\"146\"></i>\n                Approval Queue\n              </h2>\n            </div>\n            <div class=\"p-6 flex-1 flex flex-col gap-4\" data-kid=\"147\">\n              \n              <div class=\"p-4 rounded-xl bg-white/5 border border-white/5 hover:border-indigo-500/30 transition-all group\" data-kid=\"148\">\n                <div class=\"flex items-center justify-between mb-2\" data-kid=\"149\">\n                  <span class=\"text-[10px] font-mono text-indigo-400 px-1.5 py-0.5 bg-indigo-500/10 rounded\" data-kid=\"150\">EMAIL DRAFT</span>\n                  <span class=\"text-[10px] text-slate-500 italic\" data-kid=\"151\">2m ago</span>\n                </div>\n                <div class=\"text-xs text-slate-300 font-medium mb-1 truncate\" data-kid=\"152\">Follow up: Sarah @ Microsoft</div>\n                <div class=\"text-[10px] text-slate-500 line-clamp-2 leading-relaxed\" data-kid=\"153\">\n                  Hi Sarah, I saw your recent post about TradePilot's expansion...\n                </div>\n                <div class=\"mt-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"154\">\n                  <button class=\"flex-1 bg-indigo-600 hover:bg-indigo-500 text-white text-[10px] font-bold py-1.5 rounded-lg transition-colors\" data-kid=\"155\">APPROVE</button>\n                  <button class=\"px-2 bg-white/5 hover:bg-white/10 text-slate-300 rounded-lg transition-colors\" data-kid=\"156\">\n                    <i class=\"ti ti-edit text-xs\" data-kid=\"157\"></i>\n                  </button>\n                </div>\n              </div>\n\n              \n              <div class=\"p-4 rounded-xl bg-white/5 border border-white/5 hover:border-indigo-500/30 transition-all group\" data-kid=\"158\">\n                <div class=\"flex items-center justify-between mb-2\" data-kid=\"159\">\n                  <span class=\"text-[10px] font-mono text-sky-400 px-1.5 py-0.5 bg-sky-500/10 rounded\" data-kid=\"160\">LINKEDIN MSG</span>\n                  <span class=\"text-[10px] text-slate-500 italic\" data-kid=\"161\">15m ago</span>\n                </div>\n                <div class=\"text-xs text-slate-300 font-medium mb-1 truncate\" data-kid=\"162\">Connect: James @ Amazon</div>\n                <div class=\"text-[10px] text-slate-500 line-clamp-2 leading-relaxed\" data-kid=\"163\">\n                  Hey James, would love to connect and share some insights...\n                </div>\n                <div class=\"mt-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"164\">\n                  <button class=\"flex-1 bg-indigo-600 hover:bg-indigo-500 text-white text-[10px] font-bold py-1.5 rounded-lg transition-colors\" data-kid=\"165\">APPROVE</button>\n                  <button class=\"px-2 bg-white/5 hover:bg-white/10 text-slate-300 rounded-lg transition-colors\" data-kid=\"166\">\n                    <i class=\"ti ti-edit text-xs\" data-kid=\"167\"></i>\n                  </button>\n                </div>\n              </div>\n\n              <button class=\"mt-auto w-full py-3 border border-dashed border-white/10 rounded-xl text-xs text-slate-500 hover:text-slate-300 hover:bg-white/5 transition-all\" data-kid=\"168\">\n                See all 12 pending\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card rounded-2xl overflow-hidden\" data-kid=\"169\">\n          <div class=\"p-6 border-b border-white/5 flex items-center justify-between\" data-kid=\"170\">\n            <div data-kid=\"171\">\n              <h2 class=\"text-sm font-semibold text-slate-200 uppercase tracking-wider\" data-kid=\"172\">Outreach vs Conversion</h2>\n              <p class=\"text-xs text-slate-500\" data-kid=\"173\">Performance tracking across all channels (Last 30 days)</p>\n            </div>\n            <div class=\"flex gap-2\" data-kid=\"174\">\n              <button class=\"px-3 py-1.5 rounded-lg bg-white/5 text-xs text-slate-300 font-medium border border-white/5\" data-kid=\"175\">Daily</button>\n              <button class=\"px-3 py-1.5 rounded-lg bg-indigo-500 text-xs text-white font-medium shadow-lg shadow-indigo-500/20\" data-kid=\"176\">Weekly</button>\n            </div>\n          </div>\n          <div class=\"p-6 h-[300px] relative\" data-kid=\"177\">\n            <canvas id=\"outreachChart\" data-kid=\"178\"></canvas>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"179\"></script>\n<script data-kid=\"180\">\n  document.addEventListener('DOMContentLoaded', function() {\n    const ctx = document.getElementById('outreachChart').getContext('2d');\n    \n    // Gradient for the chart\n    const gradient1 = ctx.createLinearGradient(0, 0, 0, 300);\n    gradient1.addColorStop(0, 'rgba(123, 138, 242, 0.2)');\n    gradient1.addColorStop(1, 'rgba(123, 138, 242, 0)');\n\n    const gradient2 = ctx.createLinearGradient(0, 0, 0, 300);\n    gradient2.addColorStop(0, 'rgba(38, 217, 145, 0.2)');\n    gradient2.addColorStop(1, 'rgba(38, 217, 145, 0)');\n\n    new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: ['Jun 01', 'Jun 05', 'Jun 10', 'Jun 15', 'Jun 20', 'Jun 25', 'Jun 30'],\n        datasets: [\n          {\n            label: 'Outreach Volume',\n            data: [420, 580, 490, 720, 680, 850, 920],\n            borderColor: '#7b8af2',\n            backgroundColor: gradient1,\n            fill: true,\n            tension: 0.4,\n            borderWidth: 2,\n            pointRadius: 0,\n            pointHoverRadius: 6,\n            pointHoverBackgroundColor: '#7b8af2',\n            pointHoverBorderColor: '#fff',\n            pointHoverBorderWidth: 2,\n          },\n          {\n            label: 'Conversions',\n            data: [120, 180, 150, 240, 210, 280, 310],\n            borderColor: '#26d991',\n            backgroundColor: gradient2,\n            fill: true,\n            tension: 0.4,\n            borderWidth: 2,\n            pointRadius: 0,\n            pointHoverRadius: 6,\n            pointHoverBackgroundColor: '#26d991',\n            pointHoverBorderColor: '#fff',\n            pointHoverBorderWidth: 2,\n          }\n        ]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: {\n          legend: {\n            display: false\n          },\n          tooltip: {\n            mode: 'index',\n            intersect: false,\n            backgroundColor: '#0e121b',\n            titleFont: { family: 'JetBrains Mono', size: 10 },\n            bodyFont: { family: 'JetBrains Mono', size: 12 },\n            borderColor: 'rgba(255,255,255,0.1)',\n            borderWidth: 1,\n            padding: 12,\n            displayColors: true,\n            boxPadding: 6\n          }\n        },\n        scales: {\n          x: {\n            grid: {\n              display: false\n            },\n            ticks: {\n              color: '#64748b',\n              font: { family: 'JetBrains Mono', size: 10 }\n            }\n          },\n          y: {\n            grid: {\n              color: 'rgba(255,255,255,0.03)'\n            },\n            ticks: {\n              color: '#64748b',\n              font: { family: 'JetBrains Mono', size: 10 }\n            }\n          }\n        }\n      }\n    });\n\n    // Helper for sparklines\n    function createSparkline(elementId, color, data) {\n      const canvas = document.createElement('canvas');\n      document.getElementById(elementId).appendChild(canvas);\n      const ctx = canvas.getContext('2d');\n      new Chart(ctx, {\n        type: 'line',\n        data: {\n          labels: new Array(data.length).fill(''),\n          datasets: [{\n            data: data,\n            borderColor: color,\n            borderWidth: 2,\n            tension: 0.4,\n            pointRadius: 0\n          }]\n        },\n        options: {\n          responsive: true,\n          maintainAspectRatio: false,\n          plugins: { legend: { display: false }, tooltip: { enabled: false } },\n          scales: { x: { display: false }, y: { display: false } }\n        }\n      });\n    }\n\n    createSparkline('sparkline-1', '#7b8af2', [30, 45, 35, 60, 55, 70, 65]);\n    createSparkline('sparkline-2', '#7b8af2', [20, 25, 22, 30, 28, 35, 32]);\n    createSparkline('sparkline-3', '#33c2ff', [60, 55, 65, 60, 70, 75, 72]);\n    createSparkline('sparkline-4', '#fb7185', [5, 8, 4, 10, 6, 12, 8]);\n  });\n</script>",
      "comments": [],
