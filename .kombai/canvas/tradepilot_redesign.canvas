      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-bg: #0a0c11;\n    --color-surface: #0e1117;\n    --color-surface-hover: #161b22;\n    --color-primary: #7c89f8;\n    --color-success: #2ed8a7;\n    --color-info: #33c2ff;\n    --color-text-primary: #f0f3f6;\n    --color-text-secondary: #8b949e;\n    --color-border: #30363d;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: var(--color-bg);\n    color: var(--color-text-primary);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n  \n  /* Custom scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }\n  ::-webkit-scrollbar-thumb:hover { background: var(--color-text-secondary); }\n\n  .border-gradient-r {\n    border-right: 1px solid transparent;\n    border-image: linear-gradient(to bottom, transparent, var(--color-border), transparent) 1;\n  }\n</style>\n\n<div class=\"flex h-[900px] w-full overflow-hidden\" data-kid=\"1\">\n  \n  <aside class=\"w-16 flex flex-col items-center py-6 border-r border-[var(--color-border)] bg-[var(--color-bg)] shrink-0\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-[var(--color-primary)] rounded-lg flex items-center justify-center mb-10 shadow-lg shadow-indigo-500/20\" data-kid=\"3\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-6 h-6 invert\" data-kid=\"4\">\n    </div>\n    <nav class=\"flex flex-col gap-6\" data-kid=\"5\">\n      <div class=\"p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] cursor-pointer transition-colors\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"7\"></i>\n      </div>\n      <div class=\"p-2 text-[var(--color-primary)] bg-[var(--color-primary)]/10 rounded-lg cursor-pointer\" data-kid=\"8\">\n        <i class=\"ti ti-send text-2xl\" data-kid=\"9\"></i>\n      </div>\n      <div class=\"p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] cursor-pointer transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"11\"></i>\n      </div>\n      <div class=\"p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] cursor-pointer transition-colors\" data-kid=\"12\">\n        <i class=\"ti ti-inbox text-2xl\" data-kid=\"13\"></i>\n      </div>\n      <div class=\"p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] cursor-pointer transition-colors\" data-kid=\"14\">\n        <i class=\"ti ti-bar-chart-2 text-2xl\" data-kid=\"15\"></i>\n      </div>\n    </nav>\n    <div class=\"mt-auto flex flex-col gap-6\" data-kid=\"16\">\n      <div class=\"p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] cursor-pointer transition-colors\" data-kid=\"17\">\n        <i class=\"ti ti-settings text-2xl\" data-kid=\"18\"></i>\n      </div>\n      <div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 border border-[var(--color-border)]\" data-kid=\"19\"></div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col overflow-hidden bg-[var(--color-bg)]\" data-kid=\"20\">\n    \n    <header class=\"h-16 border-b border-[var(--color-border)] flex items-center justify-between px-6 bg-[var(--color-bg)]\" data-kid=\"21\">\n      <div class=\"flex items-center gap-4\" data-kid=\"22\">\n        <h1 class=\"text-lg font-semibold tracking-tight\" data-kid=\"23\">Campaigns</h1>\n        <div class=\"h-4 w-[1px] bg-[var(--color-border)]\" data-kid=\"24\"></div>\n        <div class=\"flex items-center gap-2 text-xs text-[var(--color-text-secondary)]\" data-kid=\"25\">\n          <span class=\"hover:text-[var(--color-text-primary)] cursor-pointer\" data-kid=\"26\">All Campaigns</span>\n          <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"27\"></i>\n          <span class=\"text-[var(--color-text-primary)] font-medium\" data-kid=\"28\">Enterprise Outreach Q3</span>\n        </div>\n      </div>\n\n      \n      <div class=\"relative w-[400px]\" data-kid=\"29\">\n        <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none text-[var(--color-text-secondary)]\" data-kid=\"30\">\n          <i class=\"ti ti-command text-sm mr-2\" data-kid=\"31\"></i>\n          <span class=\"text-xs\" data-kid=\"32\">Quick search...</span>\n        </div>\n        <input type=\"text\" class=\"w-full bg-[var(--color-surface)] border border-[var(--color-border)] rounded-full py-2 pl-12 pr-4 text-sm focus:outline-none focus:border-[var(--color-primary)] transition-all placeholder:text-transparent\" data-kid=\"33\">\n        <div class=\"absolute inset-y-0 right-4 flex items-center gap-2\" data-kid=\"34\">\n            <span class=\"px-1.5 py-0.5 rounded border border-[var(--color-border)] text-[10px] text-[var(--color-text-secondary)] font-mono\" data-kid=\"35\">K</span>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"36\">\n        <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-xs font-medium\" data-kid=\"37\">\n            <div class=\"w-2 h-2 rounded-full bg-[var(--color-success)] shadow-[0_0_8px_var(--color-success)]\" data-kid=\"38\"></div>\n            <span data-kid=\"39\">Health: Excellent</span>\n        </div>\n        <button class=\"bg-[var(--color-primary)] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-indigo-400 transition-colors flex items-center gap-2\" data-kid=\"40\">\n          <i class=\"ti ti-plus\" data-kid=\"41\"></i>\n          New Campaign\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 flex overflow-hidden\" data-kid=\"42\">\n      \n      <section class=\"w-[400px] border-r border-[var(--color-border)] flex flex-col bg-[var(--color-bg)]\" data-kid=\"43\">\n        <div class=\"p-4 border-b border-[var(--color-border)] flex items-center justify-between\" data-kid=\"44\">\n          <div class=\"flex items-center gap-2\" data-kid=\"45\">\n            <button class=\"p-1.5 rounded-md hover:bg-[var(--color-surface)] text-[var(--color-text-secondary)]\" data-kid=\"46\">\n              <i class=\"ti ti-filter\" data-kid=\"47\"></i>\n            </button>\n            <span class=\"text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider\" data-kid=\"48\">Active (12)</span>\n          </div>\n          <button class=\"p-1.5 rounded-md hover:bg-[var(--color-surface)] text-[var(--color-text-secondary)]\" data-kid=\"49\">\n            <i class=\"ti ti-sort-descending\" data-kid=\"50\"></i>\n          </button>\n        </div>\n\n        <div class=\"flex-1 overflow-y-auto\" data-kid=\"51\">\n          \n          <div class=\"p-4 border-b border-[var(--color-border)] bg-[var(--color-primary)]/5 border-l-2 border-l-[var(--color-primary)] cursor-pointer group\" data-kid=\"52\">\n            <div class=\"flex justify-between items-start mb-2\" data-kid=\"53\">\n              <div class=\"flex items-center gap-2\" data-kid=\"54\">\n                <div class=\"w-2 h-2 rounded-full bg-[var(--color-info)]\" data-kid=\"55\"></div>\n                <h3 class=\"text-sm font-semibold\" data-kid=\"56\">Enterprise Outreach Q3</h3>\n              </div>\n              <span class=\"text-[10px] font-mono text-[var(--color-text-secondary)]\" data-kid=\"57\">2m ago</span>\n            </div>\n            <p class=\"text-xs text-[var(--color-text-secondary)] mb-4 line-clamp-1\" data-kid=\"58\">Targeting Fortune 500 CTOs for TradePilot scale-up.</p>\n            \n            <div class=\"space-y-3\" data-kid=\"59\">\n              \n              <div data-kid=\"60\">\n                <div class=\"flex justify-between items-center text-[10px] mb-1\" data-kid=\"61\">\n                  <span class=\"text-[var(--color-text-secondary)]\" data-kid=\"62\">Sent</span>\n                  <span class=\"font-mono text-[var(--color-text-primary)]\" data-kid=\"63\">1,240 / 2,000</span>\n                </div>\n                <div class=\"h-1.5 w-full bg-[var(--color-surface)] rounded-full overflow-hidden\" data-kid=\"64\">\n                  <div class=\"h-full bg-[var(--color-info)] w-[62%]\" data-kid=\"65\"></div>\n                </div>\n              </div>\n              \n              <div data-kid=\"66\">\n                <div class=\"flex justify-between items-center text-[10px] mb-1\" data-kid=\"67\">\n                  <span class=\"text-[var(--color-text-secondary)]\" data-kid=\"68\">Replied</span>\n                  <span class=\"font-mono text-[var(--color-success)]\" data-kid=\"69\">12%</span>\n                </div>\n                <div class=\"h-1.5 w-full bg-[var(--color-surface)] rounded-full overflow-hidden\" data-kid=\"70\">\n                  <div class=\"h-full bg-[var(--color-success)] w-[12%]\" data-kid=\"71\"></div>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"mt-4 flex items-center justify-between\" data-kid=\"72\">\n                <div class=\"flex -space-x-2\" data-kid=\"73\">\n                    <img src=\"https://i.pravatar.cc/24?u=1\" class=\"w-5 h-5 rounded-full border border-[var(--color-bg)]\" data-kid=\"74\">\n                    <img src=\"https://i.pravatar.cc/24?u=2\" class=\"w-5 h-5 rounded-full border border-[var(--color-bg)]\" data-kid=\"75\">\n                    <img src=\"https://i.pravatar.cc/24?u=3\" class=\"w-5 h-5 rounded-full border border-[var(--color-bg)]\" data-kid=\"76\">\n                </div>\n                <span class=\"text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-success)]/10 text-[var(--color-success)] border border-[var(--color-success)]/20 font-medium\" data-kid=\"77\">Healthy</span>\n            </div>\n          </div>\n\n          \n          <div class=\"p-4 border-b border-[var(--color-border)] hover:bg-[var(--color-surface)] cursor-pointer transition-colors group\" data-kid=\"78\">\n            <div class=\"flex justify-between items-start mb-2\" data-kid=\"79\">\n              <div class=\"flex items-center gap-2\" data-kid=\"80\">\n                <div class=\"w-2 h-2 rounded-full bg-[var(--color-text-secondary)]\" data-kid=\"81\"></div>\n                <h3 class=\"text-sm font-semibold group-hover:text-[var(--color-primary)] transition-colors\" data-kid=\"82\">SaaS Founders Follow-up</h3>\n              </div>\n              <span class=\"text-[10px] font-mono text-[var(--color-text-secondary)]\" data-kid=\"83\">1h ago</span>\n            </div>\n            <p class=\"text-xs text-[var(--color-text-secondary)] mb-4 line-clamp-1\" data-kid=\"84\">Personalized follow-up for registered beta users.</p>\n            \n            <div class=\"space-y-3\" data-kid=\"85\">\n              <div data-kid=\"86\">\n                <div class=\"flex justify-between items-center text-[10px] mb-1\" data-kid=\"87\">\n                  <span class=\"text-[var(--color-text-secondary)]\" data-kid=\"88\">Sent</span>\n                  <span class=\"font-mono text-[var(--color-text-primary)]\" data-kid=\"89\">450 / 500</span>\n                </div>\n                <div class=\"h-1.5 w-full bg-[var(--color-surface)] rounded-full overflow-hidden\" data-kid=\"90\">\n                  <div class=\"h-full bg-[var(--color-info)] w-[90%]\" data-kid=\"91\"></div>\n                </div>\n              </div>\n              <div data-kid=\"92\">\n                <div class=\"flex justify-between items-center text-[10px] mb-1\" data-kid=\"93\">\n                  <span class=\"text-[var(--color-text-secondary)]\" data-kid=\"94\">Replied</span>\n                  <span class=\"font-mono text-[var(--color-success)]\" data-kid=\"95\">24%</span>\n                </div>\n                <div class=\"h-1.5 w-full bg-[var(--color-surface)] rounded-full overflow-hidden\" data-kid=\"96\">\n                  <div class=\"h-full bg-[var(--color-success)] w-[24%]\" data-kid=\"97\"></div>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"mt-4 flex items-center justify-between\" data-kid=\"98\">\n                <div class=\"flex -space-x-2\" data-kid=\"99\">\n                    <img src=\"https://i.pravatar.cc/24?u=4\" class=\"w-5 h-5 rounded-full border border-[var(--color-bg)]\" data-kid=\"100\">\n                    <img src=\"https://i.pravatar.cc/24?u=5\" class=\"w-5 h-5 rounded-full border border-[var(--color-bg)]\" data-kid=\"101\">\n                </div>\n                <span class=\"text-[10px] px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 font-medium\" data-kid=\"102\">Warmup</span>\n            </div>\n          </div>\n\n          \n          <div class=\"p-4 border-b border-[var(--color-border)] hover:bg-[var(--color-surface)] cursor-pointer transition-colors group opacity-70\" data-kid=\"103\">\n            <div class=\"flex justify-between items-start mb-2\" data-kid=\"104\">\n              <div class=\"flex items-center gap-2\" data-kid=\"105\">\n                <div class=\"w-2 h-2 rounded-full border border-[var(--color-text-secondary)]\" data-kid=\"106\"></div>\n                <h3 class=\"text-sm font-semibold\" data-kid=\"107\">Web3 VC Outreach</h3>\n              </div>\n              <span class=\"text-[10px] font-mono text-[var(--color-text-secondary)]\" data-kid=\"108\">Draft</span>\n            </div>\n            <p class=\"text-xs text-[var(--color-text-secondary)] mb-4 line-clamp-1\" data-kid=\"109\">Initial sequence for crypto-native investment funds.</p>\n            <div class=\"mt-4 flex items-center justify-between\" data-kid=\"110\">\n                <div class=\"flex items-center gap-2 text-[10px] text-[var(--color-text-secondary)]\" data-kid=\"111\">\n                    <i class=\"ti ti-clock\" data-kid=\"112\"></i>\n                    <span data-kid=\"113\">Created 2 days ago</span>\n                </div>\n                <span class=\"text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-border)] text-[var(--color-text-secondary)] border border-[var(--color-border)] font-medium uppercase tracking-tighter\" data-kid=\"114\">Draft</span>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"flex-1 flex flex-col overflow-hidden bg-[var(--color-surface)]\" data-kid=\"115\">\n        \n        <div class=\"p-6 border-b border-[var(--color-border)] bg-[var(--color-bg)] flex justify-between items-start\" data-kid=\"116\">\n          <div data-kid=\"117\">\n            <div class=\"flex items-center gap-3 mb-1\" data-kid=\"118\">\n                <h2 class=\"text-2xl font-bold tracking-tight\" data-kid=\"119\">Enterprise Outreach Q3</h2>\n                <span class=\"px-2 py-0.5 rounded text-[10px] font-bold bg-[var(--color-info)]/10 text-[var(--color-info)] border border-[var(--color-info)]/20 uppercase tracking-widest\" data-kid=\"120\">Active</span>\n            </div>\n            <p class=\"text-sm text-[var(--color-text-secondary)]\" data-kid=\"121\">Modified yesterday at 4:32 PM by Yash V.</p>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"122\">\n            <button class=\"p-2 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors text-[var(--color-text-secondary)]\" data-kid=\"123\">\n                <i class=\"ti ti-settings text-lg\" data-kid=\"124\"></i>\n            </button>\n            <button class=\"p-2 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-colors text-[var(--color-text-secondary)]\" data-kid=\"125\">\n                <i class=\"ti ti-share text-lg\" data-kid=\"126\"></i>\n            </button>\n            <div class=\"w-[1px] h-8 bg-[var(--color-border)] mx-1\" data-kid=\"127\"></div>\n            <button class=\"bg-[var(--color-surface-hover)] text-[var(--color-text-primary)] px-4 py-2 rounded-lg text-sm font-semibold border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-all flex items-center gap-2\" data-kid=\"128\">\n              <i class=\"ti ti-player-pause\" data-kid=\"129\"></i>\n              Pause\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"flex border-b border-[var(--color-border)] px-6 bg-[var(--color-bg)]\" data-kid=\"130\">\n            <button class=\"px-4 py-3 text-sm font-medium border-b-2 border-[var(--color-primary)] text-[var(--color-primary)]\" data-kid=\"131\">Sequence</button>\n            <button class=\"px-4 py-3 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors\" data-kid=\"132\">Leads</button>\n            <button class=\"px-4 py-3 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors\" data-kid=\"133\">Analytics</button>\n            <button class=\"px-4 py-3 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors\" data-kid=\"134\">Settings</button>\n        </div>\n\n        \n        <div class=\"flex-1 overflow-y-auto p-8 relative\" data-kid=\"135\">\n            \n            <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(var(--color-text-secondary) 0.5px, transparent 0.5px); background-size: 24px 24px;\" data-kid=\"136\"></div>\n\n            <div class=\"max-w-3xl mx-auto space-y-6 relative z-10\" data-kid=\"137\">\n                \n                \n                <div class=\"relative pl-12\" data-kid=\"138\">\n                    <div class=\"absolute left-4 top-0 bottom-0 w-[1px] bg-[var(--color-border)]\" data-kid=\"139\"></div>\n                    <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center z-20 text-[var(--color-primary)] shadow-lg\" data-kid=\"140\">\n                        <i class=\"ti ti-mail\" data-kid=\"141\"></i>\n                    </div>\n                    \n                    <div class=\"bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl overflow-hidden shadow-xl\" data-kid=\"142\">\n                        <div class=\"p-4 border-b border-[var(--color-border)] flex items-center justify-between bg-[var(--color-surface-hover)]/30\" data-kid=\"143\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"144\">\n                                <span class=\"text-[10px] font-bold text-[var(--color-text-secondary)] uppercase tracking-widest\" data-kid=\"145\">Step 1</span>\n                                <h4 class=\"text-sm font-semibold\" data-kid=\"146\">Initial Outreach</h4>\n                            </div>\n                            <div class=\"flex items-center gap-2\" data-kid=\"147\">\n                                <span class=\"text-[10px] text-[var(--color-text-secondary)] bg-[var(--color-surface)] px-2 py-0.5 rounded\" data-kid=\"148\">A/B Testing On</span>\n                                <button class=\"text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]\" data-kid=\"149\">\n                                    <i class=\"ti ti-dots-vertical\" data-kid=\"150\"></i>\n                                </button>\n                            </div>\n                        </div>\n                        <div class=\"p-5\" data-kid=\"151\">\n                            <div class=\"space-y-3 mb-4\" data-kid=\"152\">\n                                <div class=\"flex items-center gap-3 text-xs\" data-kid=\"153\">\n                                    <span class=\"text-[var(--color-text-secondary)] w-16 uppercase tracking-tighter\" data-kid=\"154\">Subject:</span>\n                                    <span class=\"text-[var(--color-text-primary)] font-medium\" data-kid=\"155\">Quick question regarding {{company_name}} trade flow</span>\n                                </div>\n                                <div class=\"h-[1px] bg-[var(--color-border)]/50\" data-kid=\"156\"></div>\n                            </div>\n                            <div class=\"text-xs text-[var(--color-text-secondary)] leading-relaxed space-y-3\" data-kid=\"157\">\n                                <p data-kid=\"158\">Hi {{first_name}},</p>\n                                <p data-kid=\"159\">I've been following your recent expansion into the B2B sector and noticed some potential optimizations in your trade outreach workflow...</p>\n                                <p data-kid=\"160\">Best,<br data-kid=\"161\">Yash</p>\n                            </div>\n                        </div>\n                        <div class=\"p-3 bg-[var(--color-surface-hover)]/20 border-t border-[var(--color-border)] flex gap-4\" data-kid=\"162\">\n                            <div class=\"flex items-center gap-1.5 text-[10px] text-[var(--color-success)] font-medium\" data-kid=\"163\">\n                                <i class=\"ti ti-chart-arrows-vertical\" data-kid=\"164\"></i>\n                                <span data-kid=\"165\">34% Open Rate</span>\n                            </div>\n                            <div class=\"flex items-center gap-1.5 text-[10px] text-[var(--color-info)] font-medium\" data-kid=\"166\">\n                                <i class=\"ti ti-click\" data-kid=\"167\"></i>\n                                <span data-kid=\"168\">8% Click Rate</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"relative pl-12 py-2\" data-kid=\"169\">\n                    <div class=\"absolute left-4 top-0 bottom-0 w-[1px] bg-[var(--color-border)]\" data-kid=\"170\"></div>\n                    <div class=\"flex items-center gap-3 text-[10px] font-bold text-[var(--color-text-secondary)] uppercase tracking-widest italic ml-2\" data-kid=\"171\">\n                        <i class=\"ti ti-clock-hour-4\" data-kid=\"172\"></i>\n                        Wait 2 days\n                    </div>\n                </div>\n\n                \n                <div class=\"relative pl-12\" data-kid=\"173\">\n                    <div class=\"absolute left-4 top-0 bottom-0 w-[1px] bg-[var(--color-border)]\" data-kid=\"174\"></div>\n                    <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center z-20 text-[#0077b5] shadow-lg\" data-kid=\"175\">\n                        <i class=\"ti ti-brand-linkedin\" data-kid=\"176\"></i>\n                    </div>\n                    \n                    <div class=\"bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl overflow-hidden shadow-xl\" data-kid=\"177\">\n                        <div class=\"p-4 border-b border-[var(--color-border)] flex items-center justify-between bg-[var(--color-surface-hover)]/30\" data-kid=\"178\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"179\">\n                                <span class=\"text-[10px] font-bold text-[var(--color-text-secondary)] uppercase tracking-widest\" data-kid=\"180\">Step 2</span>\n                                <h4 class=\"text-sm font-semibold\" data-kid=\"181\">LinkedIn Connection</h4>\n                            </div>\n                            <button class=\"text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]\" data-kid=\"182\">\n                                <i class=\"ti ti-dots-vertical\" data-kid=\"183\"></i>\n                            </button>\n                        </div>\n                        <div class=\"p-5\" data-kid=\"184\">\n                            <div class=\"text-xs text-[var(--color-text-secondary)] leading-relaxed italic border-l-2 border-[var(--color-border)] pl-4\" data-kid=\"185\">\n                                \"Sent an email your way, would love to connect here as well!\"\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"relative pl-12 py-2\" data-kid=\"186\">\n                    <div class=\"absolute left-4 top-0 bottom-0 w-[1px] bg-[var(--color-border)]\" data-kid=\"187\"></div>\n                    <div class=\"flex items-center gap-3 text-[10px] font-bold text-[var(--color-text-secondary)] uppercase tracking-widest italic ml-2\" data-kid=\"188\">\n                        <i class=\"ti ti-clock-hour-4\" data-kid=\"189\"></i>\n                        Wait 3 days\n                    </div>\n                </div>\n\n                \n                <div class=\"relative pl-12\" data-kid=\"190\">\n                    <div class=\"absolute left-4 top-0 h-10 w-[1px] bg-[var(--color-border)]\" data-kid=\"191\"></div>\n                    <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center z-20 text-[var(--color-primary)] shadow-lg\" data-kid=\"192\">\n                        <i class=\"ti ti-mail\" data-kid=\"193\"></i>\n                    </div>\n                    \n                    <div class=\"bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl overflow-hidden shadow-xl opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"194\">\n                        <div class=\"p-4 border-b border-[var(--color-border)] flex items-center justify-between bg-[var(--color-surface-hover)]/30\" data-kid=\"195\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"196\">\n                                <span class=\"text-[10px] font-bold text-[var(--color-text-secondary)] uppercase tracking-widest\" data-kid=\"197\">Step 3</span>\n                                <h4 class=\"text-sm font-semibold\" data-kid=\"198\">Follow-up Bump</h4>\n                            </div>\n                            <button class=\"text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]\" data-kid=\"199\">\n                                <i class=\"ti ti-dots-vertical\" data-kid=\"200\"></i>\n                            </button>\n                        </div>\n                        <div class=\"p-5 flex items-center justify-center border-2 border-dashed border-[var(--color-border)] m-4 rounded-lg cursor-pointer hover:border-[var(--color-primary)] transition-all\" data-kid=\"201\">\n                            <div class=\"text-center py-4\" data-kid=\"202\">\n                                <i class=\"ti ti-plus text-2xl text-[var(--color-text-secondary)] mb-2\" data-kid=\"203\"></i>\n                                <p class=\"text-xs font-medium text-[var(--color-text-secondary)]\" data-kid=\"204\">Choose follow-up template</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex justify-center pt-8\" data-kid=\"205\">\n                    <button class=\"flex items-center gap-2 px-6 py-3 rounded-full border-2 border-dashed border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all group\" data-kid=\"206\">\n                        <div class=\"w-6 h-6 rounded-full bg-[var(--color-surface)] flex items-center justify-center group-hover:bg-[var(--color-primary)] group-hover:text-white transition-all\" data-kid=\"207\">\n                            <i class=\"ti ti-plus\" data-kid=\"208\"></i>\n                        </div>\n                        <span class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"209\">Add Next Step</span>\n                    </button>\n                </div>\n\n            </div>\n        </div>\n\n        \n        <div class=\"p-4 bg-[var(--color-bg)] border-t border-[var(--color-border)] flex items-center justify-between relative z-20\" data-kid=\"210\">\n            <div class=\"flex items-center gap-6\" data-kid=\"211\">\n                <div class=\"flex flex-col\" data-kid=\"212\">\n                    <span class=\"text-[10px] text-[var(--color-text-secondary)] uppercase font-bold tracking-wider\" data-kid=\"213\">Total Duration</span>\n                    <span class=\"text-xs font-mono font-bold\" data-kid=\"214\">12 Days</span>\n                </div>\n                <div class=\"w-[1px] h-6 bg-[var(--color-border)]\" data-kid=\"215\"></div>\n                <div class=\"flex flex-col\" data-kid=\"216\">\n                    <span class=\"text-[10px] text-[var(--color-text-secondary)] uppercase font-bold tracking-wider\" data-kid=\"217\">Total Steps</span>\n                    <span class=\"text-xs font-mono font-bold\" data-kid=\"218\">5 Actions</span>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-3\" data-kid=\"219\">\n                <button class=\"px-6 py-2 text-sm font-semibold text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors\" data-kid=\"220\">Discard Changes</button>\n                <button class=\"px-8 py-2 bg-[var(--color-primary)] text-white rounded-lg text-sm font-bold shadow-lg shadow-indigo-500/20 hover:bg-indigo-400 transition-all\" 