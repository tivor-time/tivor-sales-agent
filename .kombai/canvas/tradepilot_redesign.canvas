      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    background-color: hsl(224, 30%, 6%);\n    color: hsl(213, 22%, 95%);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  /* Custom Scrollbar */\n  .custom-scrollbar::-webkit-scrollbar { width: 6px; }\n  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n  .custom-scrollbar::-webkit-scrollbar-thumb { background: hsl(224, 24%, 20%); border-radius: 10px; }\n\n  .bg-grid {\n    background-image: radial-gradient(hsl(224, 24%, 20%) 1px, transparent 1px);\n    background-size: 24px 24px;\n  }\n</style>\n\n<div class=\"flex h-[900px] w-full bg-grid overflow-hidden\" data-kid=\"1\">\n  \n  <aside class=\"w-16 border-r border-white/5 bg-[hsl(224,24%,9%)] flex flex-col items-center py-6 gap-8\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-indigo-500/20 rounded-lg flex items-center justify-center border border-indigo-500/30\" data-kid=\"3\">\n       <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-6 h-6\" style=\"filter: invert(53%) sepia(84%) saturate(3015%) hue-rotate(212deg) brightness(101%) contrast(101%);\" data-kid=\"4\">\n    </div>\n    <nav class=\"flex flex-col gap-4\" data-kid=\"5\">\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"8\">\n        <i class=\"ti ti-users text-xl\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"10\">\n        <i class=\"ti ti-send text-xl\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"12\">\n        <i class=\"ti ti-inbox text-xl\" data-kid=\"13\"></i>\n      </button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400 border border-indigo-500/20\" data-kid=\"14\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"15\"></i>\n      </button>\n    </nav>\n  </aside>\n\n  \n  <div class=\"flex-1 flex flex-col h-full\" data-kid=\"16\">\n    \n    <header class=\"h-16 border-b border-white/5 bg-[hsl(224,24%,9%)]/80 backdrop-blur-md px-8 flex items-center justify-between\" data-kid=\"17\">\n      <div class=\"flex items-center gap-4\" data-kid=\"18\">\n        <h1 class=\"text-lg font-semibold tracking-tight\" data-kid=\"19\">Workspace Settings</h1>\n        <span class=\"px-2 py-0.5 rounded border border-white/10 bg-white/5 text-[10px] font-mono text-slate-400 uppercase tracking-widest\" data-kid=\"20\">Enterprise Plan</span>\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"21\">\n        <div class=\"flex items-center gap-2 text-xs text-slate-400 font-mono\" data-kid=\"22\">\n          <span class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"23\"></span>\n          PLATFORM STABLE\n        </div>\n        <button class=\"px-4 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-sm font-medium rounded-md transition-colors shadow-lg shadow-indigo-500/10\" data-kid=\"24\">Save Changes</button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 flex overflow-hidden\" data-kid=\"25\">\n      \n      <nav class=\"w-64 border-r border-white/5 p-6 flex flex-col gap-1\" data-kid=\"26\">\n        <button class=\"flex items-center gap-3 px-3 py-2 rounded-md bg-white/5 text-sm font-medium text-white transition-all\" data-kid=\"27\">\n          <i class=\"ti ti-building text-lg opacity-70\" data-kid=\"28\"></i>\n          Organization Profile\n        </button>\n        <button class=\"flex items-center gap-3 px-3 py-2 rounded-md text-slate-400 hover:text-white hover:bg-white/5 text-sm font-medium transition-all\" data-kid=\"29\">\n          <i class=\"ti ti-users-group text-lg opacity-70\" data-kid=\"30\"></i>\n          Team & Permissions\n        </button>\n        <button class=\"flex items-center gap-3 px-3 py-2 rounded-md text-slate-400 hover:text-white hover:bg-white/5 text-sm font-medium transition-all\" data-kid=\"31\">\n          <i class=\"ti ti-credit-card text-lg opacity-70\" data-kid=\"32\"></i>\n          Billing & Usage\n        </button>\n        <button class=\"flex items-center gap-3 px-3 py-2 rounded-md text-slate-400 hover:text-white hover:bg-white/5 text-sm font-medium transition-all\" data-kid=\"33\">\n          <i class=\"ti ti-plug-connected text-lg opacity-70\" data-kid=\"34\"></i>\n          Integrations\n        </button>\n        <button class=\"flex items-center gap-3 px-3 py-2 rounded-md text-slate-400 hover:text-white hover:bg-white/5 text-sm font-medium transition-all\" data-kid=\"35\">\n          <i class=\"ti ti-shield-lock text-lg opacity-70\" data-kid=\"36\"></i>\n          Security & Auth\n        </button>\n      </nav>\n\n      \n      <main class=\"flex-1 overflow-y-auto custom-scrollbar p-10 space-y-12\" data-kid=\"37\">\n        \n        \n        <section class=\"max-w-4xl space-y-6\" data-kid=\"38\">\n          <div class=\"space-y-1\" data-kid=\"39\">\n            <h2 class=\"text-xl font-semibold tracking-tight\" data-kid=\"40\">Organization Profile</h2>\n            <p class=\"text-sm text-slate-400\" data-kid=\"41\">Manage your company details and global workspace identifiers.</p>\n          </div>\n\n          <div class=\"grid grid-cols-2 gap-6 bg-[hsl(224,24%,9%)] p-6 rounded-xl border border-white/5 shadow-2xl\" data-kid=\"42\">\n            <div class=\"space-y-2\" data-kid=\"43\">\n              <label class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"44\">Company Name</label>\n              <input type=\"text\" value=\"TradePilot Global Inc.\" class=\"w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/20 transition-all\" data-kid=\"45\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"46\">\n              <label class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"47\">Workspace URL</label>\n              <div class=\"flex\" data-kid=\"48\">\n                <span class=\"inline-flex items-center px-3 rounded-l-lg border border-r-0 border-white/10 bg-white/5 text-slate-500 text-sm font-mono\" data-kid=\"49\">tradepilot.io/</span>\n                <input type=\"text\" value=\"tradepilot-enterprise\" class=\"flex-1 bg-black/20 border border-white/10 rounded-r-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/20 transition-all\" data-kid=\"50\">\n              </div>\n            </div>\n            <div class=\"col-span-2 space-y-2\" data-kid=\"51\">\n              <label class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"52\">Primary Outreach Domain</label>\n              <input type=\"text\" value=\"outreach.tradepilot-global.com\" class=\"w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-indigo-500/50 transition-all\" data-kid=\"53\">\n              <p class=\"text-[10px] text-slate-500 flex items-center gap-1.5\" data-kid=\"54\"><i class=\"ti ti-info-circle\" data-kid=\"55\"></i> This domain is used for all campaign tracking and deliverability verification.</p>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"max-w-4xl space-y-6\" data-kid=\"56\">\n          <div class=\"flex items-end justify-between\" data-kid=\"57\">\n            <div class=\"space-y-1\" data-kid=\"58\">\n              <h2 class=\"text-xl font-semibold tracking-tight\" data-kid=\"59\">Team & Permissions</h2>\n              <p class=\"text-sm text-slate-400\" data-kid=\"60\">Invite colleagues and manage their access levels across the platform.</p>\n            </div>\n            <button class=\"px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md text-sm font-medium transition-all flex items-center gap-2\" data-kid=\"61\">\n              <i class=\"ti ti-user-plus\" data-kid=\"62\"></i>\n              Add Member\n            </button>\n          </div>\n\n          <div class=\"bg-[hsl(224,24%,9%)] rounded-xl border border-white/5 overflow-hidden shadow-2xl\" data-kid=\"63\">\n            <table class=\"w-full text-left border-collapse\" data-kid=\"64\">\n              <thead data-kid=\"65\">\n                <tr class=\"bg-white/5\" data-kid=\"66\">\n                  <th class=\"px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"67\">Member</th>\n                  <th class=\"px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"68\">Role</th>\n                  <th class=\"px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"69\">Status</th>\n                  <th class=\"px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider\" data-kid=\"70\">Last Active</th>\n                  <th class=\"px-6 py-3\" data-kid=\"71\"></th>\n                </tr>\n              </thead>\n              <tbody class=\"divide-y divide-white/5\" data-kid=\"72\">\n                <tr class=\"hover:bg-white/[0.02] transition-colors\" data-kid=\"73\">\n                  <td class=\"px-6 py-4\" data-kid=\"74\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"75\">\n                      <div class=\"w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center border border-indigo-500/30 text-[10px] font-bold text-indigo-400\" data-kid=\"76\">JD</div>\n                      <div data-kid=\"77\">\n                        <div class=\"text-sm font-medium\" data-kid=\"78\">John Doe (You)</div>\n                        <div class=\"text-xs text-slate-500\" data-kid=\"79\">john@tradepilot.io</div>\n                      </div>\n                    </div>\n                  </td>\n                  <td class=\"px-6 py-4\" data-kid=\"80\">\n                    <span class=\"px-2 py-1 rounded text-[10px] font-mono bg-indigo-500/10 text-indigo-400 border border-indigo-500/20\" data-kid=\"81\">ADMIN</span>\n                  </td>\n                  <td class=\"px-6 py-4\" data-kid=\"82\">\n                    <div class=\"flex items-center gap-1.5 text-xs text-emerald-500 font-medium\" data-kid=\"83\">\n                      <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"84\"></span>\n                      Active\n                    </div>\n                  </td>\n                  <td class=\"px-6 py-4 text-xs text-slate-500 font-mono\" data-kid=\"85\">Just now</td>\n                  <td class=\"px-6 py-4 text-right\" data-kid=\"86\">\n                    <button class=\"text-slate-500 hover:text-white\" data-kid=\"87\"><i class=\"ti ti-dots\" data-kid=\"88\"></i></button>\n                  </td>\n                </tr>\n                <tr class=\"hover:bg-white/[0.02] transition-colors\" data-kid=\"89\">\n                  <td class=\"px-6 py-4\" data-kid=\"90\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"91\">\n                      <div class=\"w-8 h-8 rounded-full bg-amber-500/20 flex items-center justify-center border border-amber-500/30 text-[10px] font-bold text-amber-400\" data-kid=\"92\">SA</div>\n                      <div data-kid=\"93\">\n                        <div class=\"text-sm font-medium\" data-kid=\"94\">Sarah Adams</div>\n                        <div class=\"text-xs text-slate-500\" data-kid=\"95\">sarah@tradepilot.io</div>\n                      </div>\n                    </div>\n                  </td>\n                  <td class=\"px-6 py-4\" data-kid=\"96\">\n                    <span class=\"px-2 py-1 rounded text-[10px] font-mono bg-white/5 text-slate-400 border border-white/10\" data-kid=\"97\">CAMPAIGN MGR</span>\n                  </td>\n                  <td class=\"px-6 py-4\" data-kid=\"98\">\n                    <div class=\"flex items-center gap-1.5 text-xs text-emerald-500 font-medium\" data-kid=\"99\">\n                      <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"100\"></span>\n                      Active\n                    </div>\n                  </td>\n                  <td class=\"px-6 py-4 text-xs text-slate-500 font-mono\" data-kid=\"101\">2h ago</td>\n                  <td class=\"px-6 py-4 text-right\" data-kid=\"102\">\n                    <button class=\"text-slate-500 hover:text-white\" data-kid=\"103\"><i class=\"ti ti-dots\" data-kid=\"104\"></i></button>\n                  </td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </section>\n\n        \n        <section class=\"max-w-4xl space-y-6 pb-20\" data-kid=\"105\">\n          <div class=\"space-y-1\" data-kid=\"106\">\n            <h2 class=\"text-xl font-semibold tracking-tight\" data-kid=\"107\">Integration Status</h2>\n            <p class=\"text-sm text-slate-400\" data-kid=\"108\">Connect your technical stack for seamless data flow and outreach automation.</p>\n          </div>\n\n          <div class=\"grid grid-cols-2 gap-4\" data-kid=\"109\">\n            \n            <div class=\"bg-[hsl(224,24%,9%)] p-5 rounded-xl border border-white/5 flex items-start gap-4 hover:border-indigo-500/30 transition-all cursor-pointer group shadow-xl\" data-kid=\"110\">\n              <div class=\"w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center border border-blue-500/20\" data-kid=\"111\">\n                <i class=\"ti ti-mail text-2xl text-blue-400\" data-kid=\"112\"></i>\n              </div>\n              <div class=\"flex-1\" data-kid=\"113\">\n                <div class=\"flex items-center justify-between mb-1\" data-kid=\"114\">\n                  <h3 class=\"text-sm font-semibold\" data-kid=\"115\">Unipile Messaging API</h3>\n                  <span class=\"px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold border border-emerald-500/20\" data-kid=\"116\">CONNECTED</span>\n                </div>\n                <p class=\"text-xs text-slate-500 mb-4 leading-relaxed\" data-kid=\"117\">Multi-channel sync for LinkedIn, Email, and CRM messaging.</p>\n                <div class=\"flex items-center gap-3\" data-kid=\"118\">\n                   <button class=\"text-[10px] font-bold text-slate-400 hover:text-white uppercase tracking-widest\" data-kid=\"119\">Settings</button>\n                   <button class=\"text-[10px] font-bold text-indigo-400 hover:text-indigo-300 uppercase tracking-widest\" data-kid=\"120\">Sync Now</button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-[hsl(224,24%,9%)] p-5 rounded-xl border border-white/5 flex items-start gap-4 hover:border-indigo-500/30 transition-all cursor-pointer group shadow-xl\" data-kid=\"121\">\n              <div class=\"w-12 h-12 rounded-lg bg-blue-600/10 flex items-center justify-center border border-blue-600/20\" data-kid=\"122\">\n                <i class=\"ti ti-brand-linkedin text-2xl text-blue-500\" data-kid=\"123\"></i>\n              </div>\n              <div class=\"flex-1\" data-kid=\"124\">\n                <div class=\"flex items-center justify-between mb-1\" data-kid=\"125\">\n                  <h3 class=\"text-sm font-semibold\" data-kid=\"126\">LinkedIn Sales Navigator</h3>\n                  <span class=\"px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold border border-emerald-500/20\" data-kid=\"127\">ACTIVE</span>\n                </div>\n                <p class=\"text-xs text-slate-500 mb-4 leading-relaxed\" data-kid=\"128\">Automated lead extraction and LinkedIn outreach sequences.</p>\n                <div class=\"flex items-center gap-3\" data-kid=\"129\">\n                   <button class=\"text-[10px] font-bold text-slate-400 hover:text-white uppercase tracking-widest\" data-kid=\"130\">Configure</button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-[hsl(224,24%,9%)] p-5 rounded-xl border border-white/5 flex items-start gap-4 border-dashed opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all cursor-pointer group shadow-xl\" data-kid=\"131\">\n              <div class=\"w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"132\">\n                <i class=\"ti ti-database-share text-2xl text-slate-400\" data-kid=\"133\"></i>\n              </div>\n              <div class=\"flex-1\" data-kid=\"134\">\n                <div class=\"flex items-center justify-between mb-1\" data-kid=\"135\">\n                  <h3 class=\"text-sm font-semibold text-slate-400\" data-kid=\"136\">Enterprise CRM (Salesforce)</h3>\n                  <span class=\"px-2 py-0.5 rounded-full bg-white/5 text-slate-500 text-[10px] font-bold border border-white/10\" data-kid=\"137\">NOT LINKED</span>\n                </div>\n                <p class=\"text-xs text-slate-500 mb-4 leading-relaxed\" data-kid=\"138\">Bidirectional sync for leads, contacts, and conversion tracking.</p>\n                <button class=\"text-[10px] font-bold text-indigo-400 hover:text-indigo-300 uppercase tracking-widest\" data-kid=\"139\">Connect CRM</button>\n              </div>\n            </div>\n          </div>\n        </section>\n\n      </main>\n    </div>\n  </div>\n</div>",
