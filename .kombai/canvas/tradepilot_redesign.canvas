      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Inter', sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .scrollbar-thin::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  .scrollbar-thin::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .scrollbar-thin::-webkit-scrollbar-thumb {\n    background: #1e293b;\n    border-radius: 10px;\n  }\n  .scrollbar-thin::-webkit-scrollbar-thumb:hover {\n    background: #334155;\n  }\n\n  .border-gradient-b {\n    border-image: linear-gradient(to bottom, #1e293b, #334155, #1e293b) 1;\n  }\n</style>\n\n<div class=\"flex flex-col h-[900px] w-full bg-[#090e1a] text-[#f8fafc] overflow-hidden selection:bg-indigo-500/30\" data-kid=\"1\">\n  \n  <header class=\"h-14 border-b border-[#1e293b] flex items-center justify-between px-6 bg-[#0e121f]/80 backdrop-blur-md z-10 shrink-0\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-500/20 border border-indigo-500/30\" data-kid=\"4\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-5 h-5\" style=\"filter: invert(65%) sepia(85%) saturate(3000%) hue-rotate(210deg) brightness(100%) contrast(100%);\" alt=\"TradePilot Logo\" data-kid=\"5\">\n      </div>\n      <h1 class=\"text-sm font-semibold tracking-tight text-white/90\" data-kid=\"6\">TradePilot</h1>\n    </div>\n\n    \n    <div class=\"flex-1 max-w-xl px-12\" data-kid=\"7\">\n      <div class=\"relative group\" data-kid=\"8\">\n        <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\" data-kid=\"9\">\n          <i class=\"ti ti-search text-slate-500 text-sm\" data-kid=\"10\"></i>\n        </div>\n        <input type=\"text\" placeholder=\"Search leads, campaigns or type / for commands...\" class=\"w-full bg-[#161b2c] border border-[#1e293b] rounded-full py-1.5 pl-11 pr-4 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition-all placeholder:text-slate-600\" data-kid=\"11\">\n        <div class=\"absolute inset-y-0 right-4 flex items-center gap-1.5\" data-kid=\"12\">\n          <kbd class=\"px-1.5 py-0.5 rounded bg-[#090e1a] border border-[#1e293b] text-[10px] text-slate-500 font-mono\" data-kid=\"13\">⌘</kbd>\n          <kbd class=\"px-1.5 py-0.5 rounded bg-[#090e1a] border border-[#1e293b] text-[10px] text-slate-500 font-mono\" data-kid=\"14\">K</kbd>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"15\">\n      <div class=\"flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20\" data-kid=\"16\">\n        <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"17\"></div>\n        <span class=\"text-[11px] font-medium text-emerald-400\" data-kid=\"18\">Deliverability: 98%</span>\n      </div>\n      <button class=\"relative p-2 rounded-lg hover:bg-[#1e293b] transition-colors\" data-kid=\"19\">\n        <i class=\"ti ti-bell text-slate-400 text-lg\" data-kid=\"20\"></i>\n        <span class=\"absolute top-2 right-2 w-2 h-2 bg-indigo-500 rounded-full border-2 border-[#0e121f]\" data-kid=\"21\"></span>\n      </button>\n      <div class=\"w-8 h-8 rounded-full border border-[#1e293b] overflow-hidden\" data-kid=\"22\">\n        <img src=\"https://i.pravatar.cc/100?u=yash\" class=\"w-full h-full object-cover\" alt=\"User Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n      </div>\n    </div>\n  </header>\n\n  <div class=\"flex flex-1 overflow-hidden\" data-kid=\"24\">\n    \n    <aside class=\"w-64 border-r border-[#1e293b] flex flex-col bg-[#0e121f]/30 shrink-0\" data-kid=\"25\">\n      <div class=\"p-4\" data-kid=\"26\">\n        <button class=\"w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium py-2 rounded-lg transition-all shadow-lg shadow-indigo-500/10 active:scale-[0.98]\" data-kid=\"27\">\n          <i class=\"ti ti-plus text-base\" data-kid=\"28\"></i>\n          Compose\n        </button>\n      </div>\n      \n      <nav class=\"flex-1 px-3 space-y-1 overflow-y-auto scrollbar-thin\" data-kid=\"29\">\n        <div class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest px-3 py-2\" data-kid=\"30\">Mailbox</div>\n        <a href=\"#\" class=\"flex items-center justify-between px-3 py-2 rounded-lg bg-indigo-500/10 text-indigo-300 border border-indigo-500/20 group\" data-kid=\"31\">\n          <div class=\"flex items-center gap-3\" data-kid=\"32\">\n            <i class=\"ti ti-inbox text-lg\" data-kid=\"33\"></i>\n            <span class=\"text-sm font-medium\" data-kid=\"34\">Inbox</span>\n          </div>\n          <span class=\"text-xs font-mono bg-indigo-500 text-white px-1.5 py-0.5 rounded-md min-w-[20px] text-center\" data-kid=\"35\">12</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"36\">\n          <i class=\"ti ti-send text-lg\" data-kid=\"37\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"38\">Sent</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"39\">\n          <i class=\"ti ti-star text-lg\" data-kid=\"40\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"41\">Starred</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"42\">\n          <i class=\"ti ti-archive text-lg\" data-kid=\"43\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"44\">Archive</span>\n        </a>\n\n        <div class=\"pt-6 pb-2\" data-kid=\"45\">\n          <div class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest px-3\" data-kid=\"46\">Filters</div>\n        </div>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"47\">\n          <div class=\"w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.3)]\" data-kid=\"48\"></div>\n          <span class=\"text-sm font-medium\" data-kid=\"49\">Positive Intent</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"50\">\n          <div class=\"w-2 h-2 rounded-full bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.3)]\" data-kid=\"51\"></div>\n          <span class=\"text-sm font-medium\" data-kid=\"52\">Follow-ups</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-[#1e293b] hover:text-slate-200 transition-colors group\" data-kid=\"53\">\n          <div class=\"w-2 h-2 rounded-full bg-slate-500\" data-kid=\"54\"></div>\n          <span class=\"text-sm font-medium\" data-kid=\"55\">Out of Office</span>\n        </a>\n      </nav>\n\n      <div class=\"p-4 border-t border-[#1e293b] bg-[#0e121f]/50\" data-kid=\"56\">\n        <div class=\"flex items-center gap-3 p-2 rounded-lg bg-slate-800/40 border border-[#1e293b]\" data-kid=\"57\">\n          <div class=\"w-8 h-8 rounded-lg bg-indigo-500/20 flex items-center justify-center\" data-kid=\"58\">\n            <i class=\"ti ti-settings text-indigo-400\" data-kid=\"59\"></i>\n          </div>\n          <div class=\"flex-1\" data-kid=\"60\">\n            <p class=\"text-[11px] font-semibold text-white/90\" data-kid=\"61\">Workflows</p>\n            <p class=\"text-[10px] text-slate-500\" data-kid=\"62\">4 active automations</p>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <section class=\"w-[380px] border-r border-[#1e293b] flex flex-col bg-[#090e1a] shrink-0\" data-kid=\"63\">\n      <div class=\"p-4 border-b border-[#1e293b] flex items-center justify-between shrink-0\" data-kid=\"64\">\n        <h2 class=\"text-sm font-bold text-white tracking-wide\" data-kid=\"65\">All Messages</h2>\n        <div class=\"flex items-center gap-2\" data-kid=\"66\">\n          <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"67\"><i class=\"ti ti-filter text-base\" data-kid=\"68\"></i></button>\n          <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"69\"><i class=\"ti ti-dots-vertical text-base\" data-kid=\"70\"></i></button>\n        </div>\n      </div>\n\n      <div class=\"flex-1 overflow-y-auto scrollbar-thin\" data-kid=\"71\">\n        \n        <div class=\"relative p-4 bg-indigo-500/5 border-b border-[#1e293b] cursor-pointer group\" data-kid=\"72\">\n          <div class=\"absolute inset-y-0 left-0 w-1 bg-indigo-500\" data-kid=\"73\"></div>\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"74\">\n            <span class=\"text-sm font-semibold text-white\" data-kid=\"75\">Alex Rivera</span>\n            <span class=\"text-[10px] font-medium text-slate-500 font-mono uppercase tracking-tighter\" data-kid=\"76\">14:22</span>\n          </div>\n          <p class=\"text-[13px] font-medium text-indigo-300 truncate mb-1\" data-kid=\"77\">Re: Partnership Opportunity / Q3 Growth</p>\n          <p class=\"text-xs text-slate-400 line-clamp-2 mb-3\" data-kid=\"78\">Hi Team, I've reviewed the proposal and it looks solid. Can we jump on a call tomorrow to finalize the terms?</p>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"79\">\n            <span class=\"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-500/20 text-emerald-400 border border-emerald-500/20\" data-kid=\"80\">\n              POSITIVE INTENT\n            </span>\n            <span class=\"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-slate-800 text-slate-400 border border-[#1e293b]\" data-kid=\"81\">\n              TECH STACK\n            </span>\n          </div>\n        </div>\n\n        \n        <div class=\"p-4 border-b border-[#1e293b] hover:bg-[#0e121f] transition-colors cursor-pointer group\" data-kid=\"82\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"83\">\n            <span class=\"text-sm font-semibold text-slate-200\" data-kid=\"84\">Sarah Chen</span>\n            <span class=\"text-[10px] font-medium text-slate-500 font-mono tracking-tighter\" data-kid=\"85\">Yesterday</span>\n          </div>\n          <p class=\"text-[13px] font-medium text-slate-300 truncate mb-1\" data-kid=\"86\">Quick question about the pricing API</p>\n          <p class=\"text-xs text-slate-500 line-clamp-2 mb-3\" data-kid=\"87\">Does your platform support bulk seat expansion via the API or do we need to do it manually in the portal?</p>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"88\">\n            <span class=\"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/20 text-amber-400 border border-amber-500/20\" data-kid=\"89\">\n              FOLLOW UP\n            </span>\n          </div>\n        </div>\n\n        \n        <div class=\"p-4 border-b border-[#1e293b] hover:bg-[#0e121f] transition-colors cursor-pointer group opacity-60\" data-kid=\"90\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"91\">\n            <span class=\"text-sm font-semibold text-slate-400\" data-kid=\"92\">Marcus Wright</span>\n            <span class=\"text-[10px] font-medium text-slate-600 font-mono tracking-tighter\" data-kid=\"93\">Jul 12</span>\n          </div>\n          <p class=\"text-[13px] font-medium text-slate-500 truncate mb-1\" data-kid=\"94\">Out of Office: Marcus Wright</p>\n          <p class=\"text-xs text-slate-600 line-clamp-2 mb-3\" data-kid=\"95\">Thank you for your email. I am currently out of the office and will be returning on Monday, July 15th.</p>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"96\">\n            <span class=\"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-slate-800 text-slate-500 border border-slate-700/50\" data-kid=\"97\">\n              OOO\n            </span>\n          </div>\n        </div>\n\n        \n        <div class=\"p-4 border-b border-[#1e293b] hover:bg-[#0e121f] transition-colors cursor-pointer group\" data-kid=\"98\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"99\">\n            <span class=\"text-sm font-semibold text-slate-200\" data-kid=\"100\">Elena Belova</span>\n            <span class=\"text-[10px] font-medium text-slate-500 font-mono tracking-tighter\" data-kid=\"101\">Jul 11</span>\n          </div>\n          <p class=\"text-[13px] font-medium text-slate-300 truncate mb-1\" data-kid=\"102\">Demo Request for TradePilot Ent.</p>\n          <p class=\"text-xs text-slate-500 line-clamp-2 mb-3\" data-kid=\"103\">I saw your recent update on LinkedIn regarding the multi-tenant features. We'd love to see a demo...</p>\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"104\">\n            <span class=\"inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-500/20 text-emerald-400 border border-emerald-500/20\" data-kid=\"105\">\n              DEMO REQUEST\n            </span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <main class=\"flex-1 flex overflow-hidden\" data-kid=\"106\">\n      \n      <div class=\"flex-1 flex flex-col border-r border-[#1e293b] bg-[#090e1a]\" data-kid=\"107\">\n        \n        <div class=\"h-16 border-b border-[#1e293b] flex items-center justify-between px-6 shrink-0 bg-[#0e121f]/30\" data-kid=\"108\">\n          <div class=\"flex items-center gap-4\" data-kid=\"109\">\n            <div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm\" data-kid=\"110\">\n              AR\n            </div>\n            <div data-kid=\"111\">\n              <h3 class=\"text-sm font-bold text-white leading-tight\" data-kid=\"112\">Alex Rivera</h3>\n              <p class=\"text-xs text-slate-500\" data-kid=\"113\">VP of Sales @ TechFlow Solutions</p>\n            </div>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"114\">\n            <button class=\"p-2 rounded-lg hover:bg-[#1e293b] text-slate-400 transition-colors\" title=\"Move to CRM\" data-kid=\"115\">\n              <i class=\"ti ti-database text-lg\" data-kid=\"116\"></i>\n            </button>\n            <button class=\"p-2 rounded-lg hover:bg-[#1e293b] text-slate-400 transition-colors\" title=\"Mark as Resolved\" data-kid=\"117\">\n              <i class=\"ti ti-check text-lg\" data-kid=\"118\"></i>\n            </button>\n            <div class=\"h-4 w-px bg-[#1e293b] mx-2\" data-kid=\"119\"></div>\n            <button class=\"p-2 rounded-lg bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 transition-colors\" data-kid=\"120\">\n              <i class=\"ti ti-dots text-lg\" data-kid=\"121\"></i>\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 overflow-y-auto p-8 space-y-8 scrollbar-thin\" data-kid=\"122\">\n          \n          <div class=\"flex flex-col items-end gap-2 max-w-[85%] ml-auto\" data-kid=\"123\">\n            <div class=\"flex items-center gap-2 mb-1\" data-kid=\"124\">\n              <span class=\"text-[10px] font-semibold text-slate-500 font-mono tracking-wider\" data-kid=\"125\">OUTBOUND - JUL 10, 10:15 AM</span>\n              <span class=\"inline-flex items-center px-1.5 py-0.5 rounded bg-indigo-500/20 text-[9px] font-bold text-indigo-400\" data-kid=\"126\">CAMPAIGN: Q3 OUTREACH</span>\n            </div>\n            <div class=\"p-4 rounded-2xl rounded-tr-none bg-[#161b2c] border border-indigo-500/20 text-slate-200 text-sm leading-relaxed shadow-lg\" data-kid=\"127\">\n              Hi Alex,<br data-kid=\"128\"><br data-kid=\"129\">\n              I've been following TechFlow's recent expansion in the EMEA region. Given your focus on trade efficiency, I thought you'd find our new multi-tenant SaaS outreach framework interesting.<br data-kid=\"130\"><br data-kid=\"131\">\n              We've helped similar sized firms increase their B2B lead generation efficiency by 40% using our automated trade flows.<br data-kid=\"132\"><br data-kid=\"133\">\n              Would you be open to a 10-minute chat later this week?\n            </div>\n          </div>\n\n          \n          <div class=\"flex flex-col items-start gap-2 max-w-[85%]\" data-kid=\"134\">\n            <div class=\"flex items-center gap-2 mb-1\" data-kid=\"135\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"136\"></div>\n              <span class=\"text-[10px] font-semibold text-emerald-500 font-mono tracking-wider uppercase\" data-kid=\"137\">Inbound - Today, 02:22 PM</span>\n            </div>\n            <div class=\"p-4 rounded-2xl rounded-tl-none bg-[#0e121f] border border-[#1e293b] text-slate-200 text-sm leading-relaxed shadow-md\" data-kid=\"138\">\n              Hi Team,<br data-kid=\"139\"><br data-kid=\"140\">\n              I've reviewed the proposal and it looks solid. Can we jump on a call tomorrow to finalize the terms?<br data-kid=\"141\"><br data-kid=\"142\">\n              I'm particularly interested in the API integration capabilities for our existing CRM. Looking forward to speaking.<br data-kid=\"143\"><br data-kid=\"144\">\n              Best,<br data-kid=\"145\">\n              Alex\n            </div>\n          </div>\n\n          \n          <div class=\"p-4 rounded-xl border border-dashed border-indigo-500/30 bg-indigo-500/[0.02] mt-4\" data-kid=\"146\">\n            <div class=\"flex items-center gap-2 mb-3\" data-kid=\"147\">\n              <i class=\"ti ti-sparkles text-indigo-400\" data-kid=\"148\"></i>\n              <span class=\"text-[10px] font-bold text-indigo-400 uppercase tracking-widest\" data-kid=\"149\">AI Suggested Response</span>\n            </div>\n            <p class=\"text-[13px] text-slate-400 italic mb-4\" data-kid=\"150\">\"Absolutely Alex, I'd be happy to jump on a call tomorrow. I have availability at 2 PM or 4 PM EST. We can also dive into the API documentation then...\"</p>\n            <div class=\"flex gap-2\" data-kid=\"151\">\n              <button class=\"px-3 py-1.5 rounded-md bg-indigo-500/20 text-indigo-300 text-[11px] font-bold hover:bg-indigo-500/30 transition-colors\" data-kid=\"152\">USE DRAFT</button>\n              <button class=\"px-3 py-1.5 rounded-md text-slate-500 text-[11px] font-bold hover:text-slate-400\" data-kid=\"153\">REGENERATE</button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"p-6 bg-[#0e121f]/50 border-t border-[#1e293b] shrink-0\" data-kid=\"154\">\n          <div class=\"bg-[#090e1a] border border-[#1e293b] rounded-xl overflow-hidden focus-within:border-indigo-500/50 transition-colors\" data-kid=\"155\">\n            <div class=\"flex items-center gap-1 p-2 border-b border-[#1e293b] bg-[#0e121f]/50\" data-kid=\"156\">\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"157\"><i class=\"ti ti-bold text-sm\" data-kid=\"158\"></i></button>\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"159\"><i class=\"ti ti-italic text-sm\" data-kid=\"160\"></i></button>\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"161\"><i class=\"ti ti-link text-sm\" data-kid=\"162\"></i></button>\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"163\"><i class=\"ti ti-list text-sm\" data-kid=\"164\"></i></button>\n              <div class=\"h-4 w-px bg-[#1e293b] mx-1\" data-kid=\"165\"></div>\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"166\"><i class=\"ti ti-paperclip text-sm\" data-kid=\"167\"></i></button>\n              <button class=\"p-1.5 rounded-md hover:bg-[#1e293b] text-slate-400\" data-kid=\"168\"><i class=\"ti ti-mood-smile text-sm\" data-kid=\"169\"></i></button>\n            </div>\n            <textarea placeholder=\"Write your reply...\" class=\"w-full h-32 bg-transparent p-4 text-sm focus:outline-none resize-none text-slate-200 placeholder:text-slate-600 scrollbar-thin\" data-kid=\"170\"></textarea>\n            <div class=\"flex items-center justify-between p-3 bg-[#0e121f]/30\" data-kid=\"171\">\n              <div class=\"flex items-center gap-2\" data-kid=\"172\">\n                <span class=\"text-[10px] text-slate-500 flex items-center gap-1\" data-kid=\"173\">\n                  <i class=\"ti ti-clock text-xs\" data-kid=\"174\"></i>\n                  Send later\n                </span>\n              </div>\n              <div class=\"flex items-center gap-2\" data-kid=\"175\">\n                <button class=\"px-4 py-1.5 rounded-lg text-slate-400 text-sm font-medium hover:bg-[#1e293b] transition-colors\" data-kid=\"176\">Discard</button>\n                <button class=\"px-6 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold shadow-lg shadow-indigo-500/20 transition-all flex items-center gap-2\" data-kid=\"177\">\n                  Send\n                  <i class=\"ti ti-send text-sm\" data-kid=\"178\"></i>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <aside class=\"w-[320px] flex flex-col bg-[#0e121f]/30 shrink-0 overflow-y-auto scrollbar-thin\" data-kid=\"179\">\n        <div class=\"p-6 space-y-8\" data-kid=\"180\">\n          \n          <section data-kid=\"181\">\n            <div class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-4\" data-kid=\"182\">Lead Context</div>\n            <div class=\"flex flex-col items-center p-6 rounded-2xl bg-[#0e121f] border border-[#1e293b] shadow-inner mb-4\" data-kid=\"183\">\n              <div class=\"w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-4 relative\" data-kid=\"184\">\n                <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/honeycomb.svg\" class=\"w-8 h-8\" style=\"filter: invert(100%);\" alt=\"Company Logo\" data-kid=\"185\">\n                <div class=\"absolute -bottom-1 -right-1 w-6 h-6 rounded-lg bg-emerald-500 border-4 border-[#0e121f] flex items-center justify-center\" data-kid=\"186\">\n                  <i class=\"ti ti-check text-[10px] text-white\" data-kid=\"187\"></i>\n                </div>\n              </div>\n              <h4 class=\"text-base font-bold text-white mb-1\" data-kid=\"188\">TechFlow Solutions</h4>\n              <p class=\"text-xs text-slate-400 mb-3 text-center\" data-kid=\"189\">B2B Software • 500-1000 Employees</p>\n              <div class=\"flex gap-2\" data-kid=\"190\">\n                <button class=\"p-2 rounded-lg bg-[#161b2c] border border-[#1e293b] text-slate-400 hover:text-white transition-colors\" data-kid=\"191\">\n                  <i class=\"ti ti-brand-linkedin text-lg\" data-kid=\"192\"></i>\n                </button>\n                <button class=\"p-2 rounded-lg bg-[#161b2c] border border-[#1e293b] text-slate-400 hover:text-white transition-colors\" data-kid=\"193\">\n                  <i class=\"ti ti-world text-lg\" data-kid=\"194\"></i>\n                </button>\n                <button class=\"p-2 rounded-lg bg-[#161b2c] border border-[#1e293b] text-slate-400 hover:text-white transition-colors\" data-kid=\"195\">\n                  <i class=\"ti ti-mail text-lg\" data-kid=\"196\"></i>\n                </button>\n              </div>\n            </div>\n          </section>\n\n          \n          <section data-kid=\"197\">\n            <div class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-4\" data-kid=\"198\">Engagement Score</div>\n            <div class=\"grid grid-cols-2 gap-3\" data-kid=\"199\">\n              <div class=\"p-3 rounded-xl bg-[#090e1a] border border-[#1e293b]\" data-kid=\"200\">\n                <p class=\"text-[10px] text-slate-500 font-medium mb-1 uppercase tracking-tighter\" data-kid=\"201\">Replies</p>\n                <p class=\"text-xl font-mono text-white font-bold\" data-kid=\"202\">04</p>\n              </div>\n              <div class=\"p-3 rounded-xl bg-[#090e1a] border border-[#1e293b]\" data-kid=\"203\">\n                <p class=\"text-[10px] text-slate-500 font-medium mb-1 uppercase tracking-tighter\" data-kid=\"204\">Opens</p>\n                <p class=\"text-xl font-mono text-white font-bold\" data-kid=\"205\">18</p>\n              </div>\n            </div>\n          </section>\n\n          \n          <section data-kid=\"206\">\n            <div class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-4\" data-kid=\"207\">Campaign Timeline</div>\n            <div class=\"relative space-y-6 before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-px before:bg-[#1e293b]\" data-kid=\"208\">\n              <div class=\"relative pl-8 group\" data-kid=\"209\">\n                <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center\" data-kid=\"210\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-indigo-500\" data-kid=\"211\"></div>\n                </div>\n                <div data-kid=\"212\">\n                  <p class=\"text-[11px] font-bold text-white leading-tight\" data-kid=\"213\">Replied to Proposal</p>\n                  <p class=\"text-[10px] text-slate-500 font-mono mt-0.5\" data-kid=\"214\">TODAY • 02:22 PM</p>\n                </div>\n              </div>\n              <div class=\"relative pl-8 group opacity-60\" data-kid=\"215\">\n                <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center\" data-kid=\"216\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-slate-500\" data-kid=\"217\"></div>\n                </div>\n                <div data-kid=\"218\">\n                  <p class=\"text-[11px] font-semibold text-slate-400 leading-tight\" data-kid=\"219\">Follow-up #2 Sent</p>\n                  <p class=\"text-[10px] text-slate-600 font-mono mt-0.5\" data-kid=\"220\">JUL 10 • 10:15 AM</p>\n                </div>\n              </div>\n              <div class=\"relative pl-8 group opacity-60\" data-kid=\"221\">\n                <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center\" data-kid=\"222\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-slate-500\" data-kid=\"223\"></div>\n                </div>\n                <div data-kid=\"224\">\n                  <p class=\"text-[11px] font-semibold text-slate-400 leading-tight\" data-kid=\"225\">Campaign Started</p>\n                  <p class=\"text-[10px] text-slate-600 font-mono mt-0.5\" data-kid=\"226\">JUL 05 • 09:00 AM</p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          \n          <section class=\"pt-4\" data-kid=\"227\">\n            <button class=\"w-full flex items-center justify-between px-4 py-2.5 rounded-xl bg-slate-800/30 border border-[#1e293b] text-slate-300 hover:text-white hover:bg-slate-800 transition-all mb-3 group\" data-kid=\"228\">\n              <span class=\"text-[11px] font-bold uppercase tracking-wider\" data-kid=\"229\">Book Meeting</span>\n              <i class=\"ti ti-calendar-plus text-lg group-hover:scale-110 transition-transform\" data-kid=\"230\"></i>\n            </button>\n            <button class=\"w-full flex items-center justify-between px-4 py-2.5 rounded-xl bg-slate-800/30 border border-[#1e293b] text-slate-300 hover:text-white hover:bg-slate-800 transition-all group\" data-kid=\"231\">\n              <span class=\"text-[11px] font-bold uppercase tracking-wider\" data-kid=\"232\">Add to Pipeline</span>\n              <i class=\"ti ti-chart-arrows text-lg group-hover:scale-110 transition-transform\" data-kid=\"233\"></i>\n            </button>\n          </section>\n        </div>\n      </aside>\n    </main>\n  </div>\n</div>",
