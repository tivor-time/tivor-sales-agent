# TradePilot environment.
#
# The app BOOTS AND IS DEMOABLE WITH ZERO SECRETS. Every variable below is
# optional — absence flips a feature flag off (graceful degradation) rather than
# crashing. Copy to `.env` and fill in what you have.

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:3000

# ---- Database (Neon / Postgres) ----
# Absent -> persistence unavailable (PGlite ephemeral fallback wired in P0 web).
DATABASE_URL=

# ---- Auth + multi-tenancy (Clerk Organizations) ----
# Absent -> single local dev tenant + dev owner user; no sign-in wall.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# ---- AI (Anthropic Claude) ----
# Absent -> drafting UI offers manual compose; auto-classification skipped.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6

# ---- Secret storage (encrypt OAuth tokens/provider keys at rest) ----
# 32 random bytes, base64. Absent -> cannot connect mailboxes/providers.
#   generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=

# ---- Email send/receive (Gmail API + Microsoft Graph) ----
# Sending stays OFF until domain auth (SPF/DKIM/DMARC) verifies, even with keys.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
MS_GRAPH_REDIRECT_URI=

# ---- Transactional email (Resend) ----
RESEND_API_KEY=

# ---- Billing (Stripe) ----
# Absent -> all tenants treated as unlimited dev plan; usage still recorded.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Durable jobs (Inngest) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Redis (Upstash) — rate limiting, idempotency, locks ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Observability (Sentry) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Trade-data providers (F1) — absent -> CSV/XLSX import only ----
VOLZA_API_KEY=
IMPORTGENIUS_API_KEY=
IMPORTKEY_API_KEY=
TENDATA_API_KEY=

# ---- Contact enrichment (F1) ----
APOLLO_API_KEY=
HUNTER_API_KEY=
