# TradePilot environment.
#
# The app BOOTS AND IS DEMOABLE WITH ZERO SECRETS. Every variable below is
# optional — absence flips a feature flag off (graceful degradation) rather than
# crashing. Copy to `.env` and fill in what you have.

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:3000

# ---- Database (Supabase Postgres) ----
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI.
# Use the "Session" pooler or direct connection (port 5432) for migrations.
# TLS is auto-enabled for supabase hosts. Absent -> PGlite ephemeral fallback.
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=

# ---- Auth + multi-tenancy (Clerk Organizations) ----
# Absent -> single local dev tenant + dev owner user; no sign-in wall.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# ---- AI (OpenAI preferred) ----
# Absent -> drafting UI offers manual compose; auto-classification skipped.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_FAST=gpt-4.1-mini

# Optional fallback provider (legacy)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6

# ---- Secret storage (encrypt OAuth tokens/provider keys at rest) ----
# 32 random bytes, base64. Absent -> cannot connect mailboxes/providers.
#   generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=

# ---- Email send/receive (Gmail API + Microsoft Graph) ----
# Sending stays OFF until domain auth (SPF/DKIM/DMARC) verifies, even with keys.
# Set ALLOW_UNVERIFIED_SENDING=true to bypass DNS checks temporarily (not recommended for production).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
MS_GRAPH_REDIRECT_URI=
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=
ALLOW_UNVERIFIED_SENDING=false

# ---- Transactional email (Resend) ----
RESEND_API_KEY=

# ---- Billing (Stripe) ----
# Absent -> all tenants treated as unlimited dev plan; usage still recorded.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Durable jobs (Inngest) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Redis (Upstash) — rate limiting, idempotency, locks ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Observability (Sentry) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Trade-data providers (F1) — absent -> CSV/XLSX import only ----
VOLZA_API_KEY=
IMPORTGENIUS_API_KEY=
IMPORTKEY_API_KEY=
TENDATA_API_KEY=

# ---- Contact enrichment (F1) ----
APOLLO_API_KEY=
HUNTER_API_KEY=
