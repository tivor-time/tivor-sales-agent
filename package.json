{
  "name": "tradepilot",
  "version": "0.1.0",
  "private": true,
  "description": "TradePilot — multi-tenant B2B trade outreach SaaS",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter @tradepilot/db generate",
    "db:migrate": "pnpm --filter @tradepilot/db migrate",
    "db:studio": "pnpm --filter @tradepilot/db studio",
    "db:seed": "pnpm --filter @tradepilot/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
